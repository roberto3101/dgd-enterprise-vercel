---
export const prerender = true;
import Principal from '@layout/Principal.astro';
import PaginaProducto from '@componentes/paginas/PaginaProducto.astro';
import Breadcrumbs from '@componentes/seo/Breadcrumbs.astro';

export async function getStaticPaths() {
  const modulos = import.meta.glob<{ default: any }>('../../../datos/en/productos.json', { eager: true });
  const productos = Object.values(modulos)[0].default;
  return Object.values(productos).map((p: any) => ({
    params: { slug: p.slug },
    props: { producto: p },
  }));
}

const { producto } = Astro.props;

const seoOverride = {
  titulo: `${producto.name} — ${producto.tagline} · Grupo DGD`,
  descripcion: producto.heroDesc || producto.tagline,
};

const productData = {
  name: producto.name,
  description: producto.heroDesc || producto.tagline,
  image: '/imagenes/dashboard-mockup.webp',
  brand: 'Codeplex Software',
  offers: (producto.plans || []).map((p: any) => ({
    name: `${producto.name} ${p.name}`,
    price: String(p.price),
    priceCurrency: 'PEN',
    description: p.desc,
  })),
};

const faqs = (producto.faq || []).map((f: any) => ({
  question: f.q,
  answer: f.a,
}));

const breadcrumbs = [
  { name: 'Home', url: '/en/' },
  { name: 'Products', url: '/en/' },
  { name: producto.name, url: `/en/productos/${producto.slug}/` },
];
---
<Principal
  idioma="en"
  pageType="product"
  seoOverride={seoOverride}
  productData={productData}
  faqs={faqs}
  breadcrumbs={breadcrumbs}
>
  <div class="container" style="padding-top:8px;"><Breadcrumbs items={breadcrumbs} /></div>
  <PaginaProducto producto={producto} idioma="en" />
</Principal>
