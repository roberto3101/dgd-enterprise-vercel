---
import Principal from '@layout/Principal.astro';
import PaginaPost from '@componentes/paginas/PaginaPost.astro';
import Breadcrumbs from '@componentes/seo/Breadcrumbs.astro';
import { cargarDatos } from '@helpers/idiomas';
import { obtenerPostBlog, obtenerPostsBlog } from '@helpers/cms';

export const prerender = false;

const idioma = 'en';
const { slug } = Astro.params;
if (!slug) return Astro.redirect('/en/blog', 302);

const datos = await cargarDatos<any>(idioma, 'blog');
const postCms = await obtenerPostBlog(idioma, slug);
const postLocal = datos.posts.find((p: any) => p.slug === slug) ?? null;
const post = postCms ?? postLocal;
if (!post) return Astro.redirect('/en/blog', 302);

const postsCms = await obtenerPostsBlog(idioma);
const todos = postsCms.length > 0 ? postsCms : datos.posts;
const related = todos.filter((p: any) => p.slug !== post.slug).slice(0, 3);

const seoOverride = {
  titulo: `${post.title} · DGD Blog`,
  descripcion: post.excerpt,
};

const articleData = {
  headline: post.title,
  description: post.excerpt,
  image: '/imagenes/abstract-navy-gold.webp',
  datePublished: post.date,
  dateModified: post.date,
  author: {
    name: post.author || 'DGD Team',
    jobTitle: post.authorRole || 'Consultant',
  },
  section: post.cat,
  keywords: `${post.cat}, SUNAT, Peru, ${post.title}`,
};

const breadcrumbs = [
  { name: 'Home', url: '/en/' },
  { name: 'Blog', url: '/en/blog/' },
  { name: post.title, url: `/en/blog/${post.slug}/` },
];
---
<Principal
  idioma="en"
  pageType="article"
  seoOverride={seoOverride}
  articleData={articleData}
  breadcrumbs={breadcrumbs}
>
  <div class="container" style="padding-top:8px;"><Breadcrumbs items={breadcrumbs} /></div>
  <PaginaPost post={post} datos={{ ...datos, posts: todos }} idioma="en" related={related} />
</Principal>
