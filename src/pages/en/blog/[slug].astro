---
import Principal from '@layout/Principal.astro';
import PaginaPost from '@componentes/paginas/PaginaPost.astro';
import Breadcrumbs from '@componentes/seo/Breadcrumbs.astro';
import { cargarDatos } from '@helpers/idiomas';

export async function getStaticPaths() {
  const modulos = import.meta.glob<{ default: any }>('../../../datos/en/blog.json', { eager: true });
  const datos = Object.values(modulos)[0].default;
  return datos.posts.map((p: any) => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const datos = await cargarDatos<any>('en', 'blog');
const related = datos.posts.filter((p: any) => p.slug !== post.slug).slice(0, 3);

const seoOverride = {
  titulo: `${post.title} · DGD Blog`,
  descripcion: post.excerpt,
};

const articleData = {
  headline: post.title,
  description: post.excerpt,
  image: '/imagenes/abstract-navy-gold.webp',
  datePublished: post.date,
  dateModified: post.dateModified || post.date,
  author: {
    name: post.author || 'DGD Team',
    jobTitle: post.authorRole || 'Consultant',
  },
  section: post.cat,
  keywords: `${post.cat}, SUNAT, Peru, ${post.title}`,
};

const breadcrumbs = [
  { name: 'Home', url: '/en/' },
  { name: 'Blog', url: '/en/blog/' },
  { name: post.title, url: `/en/blog/${post.slug}/` },
];
---
<Principal
  idioma="en"
  pageType="article"
  seoOverride={seoOverride}
  articleData={articleData}
  breadcrumbs={breadcrumbs}
>
  <div class="container" style="padding-top:8px;"><Breadcrumbs items={breadcrumbs} /></div>
  <PaginaPost post={post} datos={datos} idioma="en" related={related} />
</Principal>
