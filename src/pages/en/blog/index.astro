---
import Principal from '@layout/Principal.astro';
import PaginaBlog from '@componentes/paginas/PaginaBlog.astro';
import { cargarDatos } from '@helpers/idiomas';
import { obtenerPostsBlog, obtenerCategoriasBlog, contarCategorias } from '@helpers/cms';

export const prerender = false;

const datos = await cargarDatos<any>('en', 'blog');
const postsCms = await obtenerPostsBlog('en');
const categoriasCms = await obtenerCategoriasBlog('en');

const datosMezclados = postsCms.length > 0
  ? {
      ...datos,
      posts: postsCms,
      categorias: ['All', ...contarCategorias(postsCms, categoriasCms).map((c) => c.nombre)],
    }
  : datos;
---
<Principal idioma="en">
  <PaginaBlog datos={datosMezclados} idioma="en" />
</Principal>
