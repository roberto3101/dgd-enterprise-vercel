---
import Principal from '@layout/Principal.astro';
import PaginaBlog from '@componentes/paginas/PaginaBlog.astro';
import { cargarDatos } from '@helpers/idiomas';
import { obtenerPostsBlog } from '@helpers/cms';

export const prerender = false;

const datos = await cargarDatos<any>('es', 'blog');
const postsCms = await obtenerPostsBlog('es');
const datosMezclados = postsCms.length > 0 ? { ...datos, posts: postsCms } : datos;
---
<Principal idioma="es">
  <PaginaBlog datos={datosMezclados} idioma="es" />
</Principal>
