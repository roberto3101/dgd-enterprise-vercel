---
/*
  Ecosistema — Animated Beam (Magic UI pattern)
  Ref: https://magicui.design/docs/components/animated-beam (MIT)
  Puerto a Astro + CSS: 6 módulos alrededor del core DGD conectados por
  beams de luz que fluyen hacia el centro (data converging to core).
*/
interface Props { ecosistema: any; }
const { ecosistema } = Astro.props;
// SVG paths fijos por slot (no i18n) — los textos vienen de la prop.
const SVG_PATHS: Record<string, string> = {
  a: 'M3 4h18v16H3zM3 10h18M9 4v16',
  b: 'M21 16V8a2 2 0 0 0-1-1.7l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.7l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16zM3.3 7L12 12l8.7-5',
  c: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6',
  d: 'M3 2v7a3 3 0 0 0 6 0V2M6 2v20M17 2a4 4 0 0 0-4 4v5a2 2 0 0 0 2 2h2v9',
  e: 'M3 3v18h18M7 14l3-3 4 4 6-6',
  f: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
};
const modulos = ecosistema.modulos.map((m: any) => ({ ...m, svg: SVG_PATHS[m.key] }));
---
<section class="eco-beam-section">
  <div class="eco-bg-grid" aria-hidden="true"></div>
  <div class="container">
    <div class="eco-layout">
      <div class="eco-text" data-anim="reveal-up">
        <div class="eyebrow">{ecosistema.eyebrow}</div>
        <h2>{ecosistema.tituloPre}<br/><span class="eco-accent">{ecosistema.tituloAccent}</span><br/>{ecosistema.tituloPost}</h2>
        <p>{ecosistema.descripcion}</p>
        <ul class="eco-bullets">
          {ecosistema.bullets.map((b: string) => (
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold-700)" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              {b}
            </li>
          ))}
        </ul>
      </div>

      <div class="eco-visual" data-anim="reveal-scale">
        <!-- SVG: rutas estáticas + beams animados que fluyen al centro -->
        <svg class="eco-beams" viewBox="0 0 500 460" fill="none" aria-hidden="true">
          <defs>
            <linearGradient id="dgd-beam" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="100" y2="0">
              <stop offset="0%" stop-color="#F0D98C" stop-opacity="0"/>
              <stop offset="50%" stop-color="#D4AF37" stop-opacity="1"/>
              <stop offset="100%" stop-color="#B78B2B" stop-opacity="0"/>
            </linearGradient>
            <radialGradient id="dgd-core-glow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#D4AF37" stop-opacity=".45"/>
              <stop offset="100%" stop-color="#D4AF37" stop-opacity="0"/>
            </radialGradient>
          </defs>

          <!-- Glow detrás del core -->
          <circle cx="250" cy="230" r="110" fill="url(#dgd-core-glow)" class="core-glow"/>

          <!-- Rutas estáticas punteadas (visibles siempre) -->
          <path d="M 80 90   Q 180 170 250 230" class="p-static"/>
          <path d="M 40 230  L 250 230"         class="p-static"/>
          <path d="M 80 370  Q 180 290 250 230" class="p-static"/>
          <path d="M 420 90  Q 320 170 250 230" class="p-static"/>
          <path d="M 460 230 L 250 230"         class="p-static"/>
          <path d="M 420 370 Q 320 290 250 230" class="p-static"/>

          <!-- Beams animados: recorren las mismas rutas hacia el centro -->
          <path d="M 80 90   Q 180 170 250 230" class="p-beam b1"/>
          <path d="M 40 230  L 250 230"         class="p-beam b2"/>
          <path d="M 80 370  Q 180 290 250 230" class="p-beam b3"/>
          <path d="M 420 90  Q 320 170 250 230" class="p-beam b4"/>
          <path d="M 460 230 L 250 230"         class="p-beam b5"/>
          <path d="M 420 370 Q 320 290 250 230" class="p-beam b6"/>
        </svg>

        <!-- Nodos módulos -->
        {modulos.map((m: any) => (
          <div class={`node node--${m.key}`} title={m.titulo}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={m.svg}/>
            </svg>
          </div>
        ))}

        <!-- Core central DGD -->
        <div class="node-core">
          <div class="core-aura" aria-hidden="true"></div>
          <div class="core-inner">
            <div class="core-mark">{ecosistema.coreMark}</div>
            <div class="core-sub">{ecosistema.coreSub}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .eco-beam-section {
    padding: 96px 0;
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg-alt) 100%);
    position: relative; overflow: hidden;
  }
  .eco-bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--ink-300) 30%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--ink-300) 30%, transparent) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse 60% 60% at 70% 50%, black 10%, transparent 75%);
    opacity: .35;
    pointer-events: none;
  }
  .eco-layout {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 64px;
    align-items: center;
    position: relative;
  }
  @media (max-width: 980px) {
    .eco-layout { grid-template-columns: 1fr; gap: 40px; }
    .eco-beam-section { padding: 72px 0; }
  }
  .eco-text h2 { margin-top: 10px; }
  .eco-accent {
    background: linear-gradient(135deg, var(--navy-700) 20%, var(--gold-700) 90%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .eco-text p {
    margin-top: 18px; font-size: 16px; line-height: 1.65;
    color: var(--ink-700); max-width: 480px;
  }
  .eco-bullets {
    list-style: none; margin: 24px 0 0; padding: 0;
    display: flex; flex-direction: column; gap: 10px;
    font-size: 14px; color: var(--ink-700);
  }
  .eco-bullets li { display: flex; align-items: center; gap: 10px; }

  /* ============ LIENZO VISUAL ============ */
  .eco-visual {
    position: relative;
    width: 100%;
    max-width: 560px;
    aspect-ratio: 500 / 460;
    margin: 0 auto;
  }
  .eco-beams {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    overflow: visible;
  }

  /* Rutas estáticas: discretas, punteadas */
  .p-static {
    stroke: color-mix(in srgb, var(--ink-400) 55%, transparent);
    stroke-width: 1.2;
    stroke-dasharray: 3 6;
    opacity: .55;
  }

  /* Beams: arco de luz recorriendo cada ruta hacia el centro */
  .p-beam {
    stroke: url(#dgd-beam);
    stroke-width: 2.6;
    stroke-linecap: round;
    fill: none;
    stroke-dasharray: 44 540;
    stroke-dashoffset: 584;
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--gold-500) 70%, transparent));
    animation: beamFlow 3.2s cubic-bezier(.55,.15,.45,.85) infinite;
  }
  .b1 { animation-delay: 0s;    animation-duration: 3.2s; }
  .b2 { animation-delay: .45s;  animation-duration: 3.5s; }
  .b3 { animation-delay: .9s;   animation-duration: 3.0s; }
  .b4 { animation-delay: 1.3s;  animation-duration: 3.4s; }
  .b5 { animation-delay: 1.75s; animation-duration: 3.1s; }
  .b6 { animation-delay: 2.2s;  animation-duration: 3.3s; }

  @keyframes beamFlow {
    0%   { stroke-dashoffset: 584; }
    60%  { stroke-dashoffset: -44;  }
    100% { stroke-dashoffset: -44;  }
  }

  .core-glow {
    transform-origin: 250px 230px;
    animation: coreGlowPulse 3.6s ease-in-out infinite;
  }
  @keyframes coreGlowPulse {
    0%,100% { opacity: .75; transform: scale(1); }
    50%     { opacity: 1;   transform: scale(1.1); }
  }

  /* ============ NODOS ============ */
  .node {
    position: absolute;
    width: 58px; height: 58px;
    display: grid; place-items: center;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--navy-800), var(--navy-700));
    color: var(--gold-400);
    border: 1px solid color-mix(in srgb, var(--gold-500) 30%, transparent);
    box-shadow:
      0 10px 30px -12px rgba(4,26,46,.35),
      inset 0 1px 0 color-mix(in srgb, var(--gold-500) 18%, transparent);
    transform: translate(-50%, -50%);
    transition: transform .3s var(--ease-smooth), box-shadow .3s, border-color .3s;
    z-index: 2;
    cursor: default;
  }
  .node:hover {
    transform: translate(-50%, -50%) scale(1.14);
    border-color: var(--gold-500);
    box-shadow:
      0 16px 40px -10px rgba(212,175,55,.55),
      0 0 0 3px color-mix(in srgb, var(--gold-500) 30%, transparent);
    color: var(--gold-300);
  }
  /* Posiciones (coinciden con las coordenadas del viewBox 500x460) */
  .node--a { left: 16%;   top: 19.57%; }  /* (80,  90)  */
  .node--b { left: 8%;    top: 50%;    }  /* (40,  230) */
  .node--c { left: 16%;   top: 80.43%; }  /* (80,  370) */
  .node--d { left: 84%;   top: 19.57%; }  /* (420, 90)  */
  .node--e { left: 92%;   top: 50%;    }  /* (460, 230) */
  .node--f { left: 84%;   top: 80.43%; }  /* (420, 370) */

  /* ============ CORE ============ */
  .node-core {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    width: 112px; height: 112px;
    z-index: 3;
  }
  .core-aura {
    position: absolute; inset: -14px;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      color-mix(in srgb, var(--gold-500) 65%, transparent) 45deg,
      transparent 120deg,
      transparent 210deg,
      color-mix(in srgb, var(--gold-400) 55%, transparent) 260deg,
      transparent 330deg,
      transparent 360deg
    );
    filter: blur(7px);
    animation: coreSpin 8s linear infinite;
    opacity: .85;
  }
  @keyframes coreSpin { to { transform: rotate(360deg); } }
  .core-inner {
    position: relative;
    width: 100%; height: 100%;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, var(--navy-600), var(--navy-900) 72%);
    display: grid; place-items: center;
    text-align: center;
    box-shadow:
      0 0 0 5px color-mix(in srgb, var(--bg) 95%, transparent),
      0 0 0 6px color-mix(in srgb, var(--gold-500) 55%, transparent),
      0 25px 50px -10px rgba(4,26,46,.5),
      inset 0 2px 8px color-mix(in srgb, var(--gold-500) 25%, transparent);
  }
  .core-mark {
    font-size: 22px; font-weight: 800; letter-spacing: .04em;
    background: linear-gradient(135deg, var(--gold-300), var(--gold-500) 55%, var(--gold-700));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,.35));
  }
  .core-sub {
    font-size: 10px; font-weight: 700; letter-spacing: .2em;
    text-transform: uppercase; color: rgba(255,255,255,.78);
    margin-top: 4px;
  }

  /* ============ DARK MODE ============ */
  :global(html.dark) .eco-beam-section {
    background: linear-gradient(180deg, var(--bg) 0%, var(--navy-900) 100%);
  }
  :global(html.dark) .p-static {
    stroke: color-mix(in srgb, var(--ink-300) 40%, transparent);
  }

  /* ============ REDUCED MOTION ============ */
  @media (prefers-reduced-motion: reduce) {
    .p-beam, .core-glow, .core-aura { animation: none !important; }
    .p-beam { stroke-dashoffset: 0; stroke-dasharray: 4 6; opacity: .6; }
  }

  /* ============ MOBILE ============ */
  @media (max-width: 560px) {
    .eco-visual { max-width: 100%; }
    .node { width: 48px; height: 48px; border-radius: 12px; }
    .node svg { width: 18px; height: 18px; }
    .node-core { width: 92px; height: 92px; }
    .core-mark { font-size: 18px; }
    .core-sub { font-size: 9px; }
  }
</style>
