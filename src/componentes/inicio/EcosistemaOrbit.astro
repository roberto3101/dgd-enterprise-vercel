---
import OrbitingCircles from '@componentes/ui/mui/OrbitingCircles.astro';
---
<section class="eco-orbit">
  <div class="container">
    <div class="eco-grid">
      <div class="eco-text" data-anim="reveal-up">
        <div class="eyebrow">El ecosistema</div>
        <h2>Una suite cloud,<br/><span class="eco-accent">varios módulos</span><br/>conectados.</h2>
        <p>
          ContaPlex, GestiónPlex y Facturación Electrónica comparten la misma base de datos,
          usuarios y reglas contables. Implementas uno, y cuando sumes otro ya está listo —
          sin migraciones ni dobles digitaciones.
        </p>
        <ul class="eco-bullets">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold-700)" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Datos únicos entre módulos
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold-700)" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Actualizaciones simultáneas
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold-700)" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Soporte unificado desde Perú
          </li>
        </ul>
      </div>

      <div class="eco-visual" data-anim="reveal-scale">
        <OrbitingCircles radius={150} duration={28} iconSize={56} count={4}>
          <div slot="item-0" class="eco-chip eco-chip--primary" title="ContaPlex">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="9" y1="4" x2="9" y2="20"/></svg>
          </div>
          <div slot="item-1" class="eco-chip eco-chip--primary" title="GestiónPlex">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.7l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.7l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.3 7 12 12 20.7 7"/></svg>
          </div>
          <div slot="item-2" class="eco-chip eco-chip--primary" title="Facturación SUNAT">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <div slot="item-3" class="eco-chip" title="POS Restaurante">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7a3 3 0 0 0 6 0V2M6 2v20M17 2a4 4 0 0 0-4 4v5a2 2 0 0 0 2 2h2v9"/></svg>
          </div>
        </OrbitingCircles>

        <!-- Órbita interna más pequeña (reverse) -->
        <div class="eco-inner-orbit">
          <OrbitingCircles radius={80} duration={18} iconSize={36} reverse={true} count={3} path={false}>
            <div slot="item-0" class="eco-chip eco-chip--small">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.7-4 3-9 3s-9-1.3-9-3"/><path d="M3 5v14c0 1.7 4 3 9 3s9-1.3 9-3V5"/></svg>
            </div>
            <div slot="item-1" class="eco-chip eco-chip--small">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            </div>
            <div slot="item-2" class="eco-chip eco-chip--small">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
          </OrbitingCircles>
        </div>

        <!-- Centro: logo DGD -->
        <div class="eco-center">
          <div class="eco-center-inner">
            <div class="eco-center-mark">DGD</div>
            <div class="eco-center-sub">Partner</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .eco-orbit {
    padding: 96px 0;
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg-alt) 100%);
    position: relative; overflow: hidden;
  }
  .eco-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 64px;
    align-items: center;
  }
  @media (max-width: 980px) {
    .eco-grid { grid-template-columns: 1fr; gap: 48px; }
    .eco-orbit { padding: 72px 0; }
  }
  .eco-text h2 { margin-top: 10px; }
  .eco-accent {
    background: linear-gradient(135deg, var(--navy-700) 20%, var(--gold-700) 90%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .eco-text p {
    margin-top: 18px; font-size: 16px; line-height: 1.65;
    color: var(--ink-700); max-width: 480px;
  }
  .eco-bullets {
    list-style: none; margin: 24px 0 0; padding: 0;
    display: flex; flex-direction: column; gap: 10px;
    font-size: 14px; color: var(--ink-700);
  }
  .eco-bullets li { display: flex; align-items: center; gap: 10px; }

  .eco-visual {
    position: relative;
    display: grid; place-items: center;
    min-height: 460px;
  }
  .eco-inner-orbit {
    position: absolute; inset: 0;
    display: grid; place-items: center;
    pointer-events: none;
  }

  .eco-chip {
    width: 100%; height: 100%;
    display: grid; place-items: center;
    border-radius: 14px;
    background: var(--bg-card);
    border: 1px solid var(--ink-200);
    color: var(--navy-700);
    box-shadow: 0 6px 20px -8px rgba(4,26,46,.15);
  }
  .eco-chip--primary {
    background: linear-gradient(135deg, var(--navy-800), var(--navy-700));
    color: var(--gold-400);
    border-color: color-mix(in srgb, var(--gold-500) 30%, transparent);
    box-shadow: 0 10px 30px -12px rgba(4,26,46,.35);
  }
  .eco-chip--small {
    border-radius: 10px;
    background: var(--bg-card);
    color: var(--ink-500);
    box-shadow: 0 2px 8px -4px rgba(4,26,46,.1);
  }

  .eco-center {
    position: relative; z-index: 2;
    width: 110px; height: 110px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, var(--navy-600), var(--navy-900) 70%);
    display: grid; place-items: center;
    box-shadow:
      0 0 0 6px rgba(255,255,255,.6),
      0 0 0 7px color-mix(in srgb, var(--gold-500) 30%, transparent),
      0 25px 50px -10px rgba(4,26,46,.4);
  }
  .eco-center-inner { text-align: center; color: white; }
  .eco-center-mark {
    font-size: 20px; font-weight: 800; letter-spacing: 0.02em;
    color: var(--gold-400);
  }
  .eco-center-sub {
    font-size: 10px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: rgba(255,255,255,.7);
    margin-top: 2px;
  }

  :global(html.dark) .eco-orbit {
    background: linear-gradient(180deg, var(--bg) 0%, var(--navy-900) 100%);
  }
</style>
