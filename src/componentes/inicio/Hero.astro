---
import BorderBeam from '@componentes/ui/mui/BorderBeam.astro';
import DotPattern from '@componentes/ui/mui/DotPattern.astro';
interface Props {
  hero: any;
}
const { hero } = Astro.props;
const d = hero.dashboard;
// Video de stock sin copyright (Pexels / free commercial use). Fallback: gradient.
const heroVideo = "https://videos.pexels.com/video-files/8419153/8419153-uhd_2560_1440_25fps.mp4";
---
<section class="hero">
  <video class="hero-video" autoplay muted loop playsinline preload="none" poster="">
    <source src={heroVideo} type="video/mp4" />
  </video>
  <div class="hero-bg"></div>
  <div class="hero-grid-bg"></div>

  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="row" style="gap:8px; margin-bottom:24px" data-anim="reveal-up">
          <span class="badge badge-pop">{hero.badgePartner}</span>
          <span class="badge">{hero.badgeSunat}</span>
        </div>
        <h1 data-anim="hero-title">
          {hero.tituloPre}<span class="gradient-text">{hero.tituloGradient}</span>{hero.tituloPost}
        </h1>
        <p data-anim="reveal-up" style="font-size:19px; margin-top:22px; max-width:560px; color:var(--ink-500); line-height:1.6" set:html={hero.descripcion}></p>

        <div class="row" style="margin-top:32px; gap:12px" data-anim="reveal-up">
          <a class="btn btn-primary btn-lg btn-shine" href="#contacto">
            {hero.ctaPrimario}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a class="btn btn-outline btn-lg" href="#planes">{hero.ctaSecundario}</a>
        </div>

        <div style="margin-top:36px; display:flex; gap:24px; flex-wrap:wrap; font-size:13px; color:var(--ink-500)" data-anim="stagger">
          {hero.bullets.map((b: string) => (
            <div style="display:flex; align-items:center; gap:6px">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold-700)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {b}
            </div>
          ))}
        </div>
      </div>

      <div style="position:relative" data-anim="reveal-right">
        <div class="gradient-border" style="animation: floatY 6s ease-in-out infinite; position: relative">
          <BorderBeam size={100} duration={9} colorFrom="#D4AF37" colorTo="#175082" borderWidth={1.5} />
          <div class="dash" style="font-family: var(--font); box-shadow: var(--shadow-xl)">
            <div class="dash-chrome">
              <div class="dash-dot r"></div><div class="dash-dot y"></div><div class="dash-dot g"></div>
              <div class="dash-url">{d.url}</div>
            </div>
            <div style="display:grid; grid-template-columns:180px 1fr; min-height:420px; background:var(--bg-card)">
              <aside style="background:var(--bg-alt); border-right:1px solid var(--ink-200); padding:16px">
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:24px">
                  <div style="width:26px; height:26px; border-radius:7px; background:linear-gradient(135deg,var(--navy-700),var(--gold-500)); display:grid; place-items:center; color:white; font-size:12px; font-weight:800">C</div>
                  <span style="font-weight:700; font-size:14px">ContaPlex</span>
                </div>
                {d.sidebar.map((x: string, i: number) => (
                  <div style={`padding:8px 10px; font-size:13px; border-radius:6px; margin-bottom:2px; background:${i===0?'var(--bg-card)':'transparent'}; color:${i===0?'var(--ink-900)':'var(--ink-500)'}; font-weight:${i===0?600:500}; display:flex; align-items:center; gap:8px; ${i===0?'box-shadow:var(--shadow-sm)':''}`}>
                    <div style={`width:6px; height:6px; border-radius:2px; background:${i===0?'var(--gold-500)':'var(--ink-300)'}`}></div>
                    {x}
                  </div>
                ))}
              </aside>
              <main style="padding:20px">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px">
                  <div>
                    <div style="font-size:11px; color:var(--ink-500); text-transform:uppercase; letter-spacing:.08em; font-weight:600">{d.eyebrow}</div>
                    <div style="font-size:18px; font-weight:700; margin-top:2px">{d.titulo}</div>
                  </div>
                  <div style="display:flex; gap:6px">
                    <div style="padding:5px 10px; background:color-mix(in srgb, var(--gold-500) 18%, transparent); color:var(--gold-700); border-radius:6px; font-size:11px; font-weight:600">{d.tags[0]}</div>
                    <div style="padding:5px 10px; background:var(--ink-100); color:var(--ink-700); border-radius:6px; font-size:11px; font-weight:600">{d.tags[1]}</div>
                  </div>
                </div>
                <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:14px">
                  {d.metricas.map((s: any) => (
                    <div style="padding:12px; border:1px solid var(--ink-200); border-radius:10px; background:var(--bg-card)">
                      <div style="font-size:10px; color:var(--ink-500); text-transform:uppercase; font-weight:600; letter-spacing:.06em">{s.label}</div>
                      <div style="font-size:18px; font-weight:700; margin:4px 0">{s.valor}</div>
                      <div style={`font-size:11px; color:${s.delta.startsWith('+')?'var(--gold-700)':'#EF4444'}; font-weight:600`}>{s.delta}</div>
                    </div>
                  ))}
                </div>
                <div style="padding:14px; border:1px solid var(--ink-200); border-radius:10px; background:var(--bg-card)">
                  <div style="display:flex; justify-content:space-between; margin-bottom:10px">
                    <div style="font-size:12px; font-weight:600">{d.chart.titulo}</div>
                    <div style="font-size:11px; color:var(--ink-500)">{d.chart.subtitulo}</div>
                  </div>
                  <svg viewBox="0 0 300 90" style="width:100%; height:90px">
                    <defs>
                      <linearGradient id="g1" x1="0" x2="0" y1="0" y2="1">
                        <stop offset="0" stop-color="#D4AF37" stop-opacity=".45"/>
                        <stop offset="1" stop-color="#D4AF37" stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                    <path d="M0,70 L50,55 L100,60 L150,40 L200,45 L250,25 L300,30 L300,90 L0,90 Z" fill="url(#g1)"/>
                    <path d="M0,70 L50,55 L100,60 L150,40 L200,45 L250,25 L300,30" fill="none" stroke="#B78B2B" stroke-width="2"/>
                    {[70,55,60,40,45,25,30].map((y, i) => (
                      <circle cx={i*50} cy={y} r="3" fill="white" stroke="#B78B2B" stroke-width="2"/>
                    ))}
                  </svg>
                  <div style="display:flex; justify-content:space-between; font-size:10px; color:var(--ink-500); margin-top:6px">
                    {d.chart.meses.map((m: string) => <span>{m}</span>)}
                  </div>
                </div>
              </main>
            </div>
          </div>
        </div>

        <div class="glass" style="position:absolute; top:-20px; right:-10px; border-radius:12px; padding:12px 14px; display:flex; align-items:center; gap:10px; animation: floatY 5s ease-in-out infinite .5s">
          <div style="width:36px; height:36px; border-radius:9px; background:linear-gradient(135deg,var(--gold-500),var(--gold-700)); color:var(--navy-900); display:grid; place-items:center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div style="font-size:11px; color:var(--ink-500); font-weight:600">{d.floatingTop.titulo}</div>
            <div style="font-size:13px; font-weight:700">{d.floatingTop.subtitulo}</div>
          </div>
        </div>
        <div class="glass" style="position:absolute; bottom:-16px; left:-24px; border-radius:12px; padding:14px 16px; animation: floatY 7s ease-in-out infinite 1s">
          <div style="font-size:10px; color:var(--ink-500); font-weight:600; text-transform:uppercase; letter-spacing:.06em">{d.floatingBottom.eyebrow}</div>
          <div style="font-size:20px; font-weight:800; margin:2px 0; background:linear-gradient(135deg,var(--navy-700),var(--gold-500)); -webkit-background-clip:text; background-clip:text; color:transparent">{d.floatingBottom.monto}</div>
          <div style="font-size:11px; color:var(--gold-700); font-weight:600">{d.floatingBottom.delta}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Marquee: módulos reales de la suite Codeplex -->
<section style="padding:28px 0; background:var(--bg-alt); border-top:1px solid var(--ink-200); border-bottom:1px solid var(--ink-200)">
  <div class="marquee">
    <div class="marquee-track">
      {["ContaPlex · Contabilidad cloud","GestiónPlex · Inventarios","Facturación Electrónica","SIRE · RCE · RVIE","PLE · Libros electrónicos","Kárdex valorizado","Multi-almacén","POS · Restaurante","DAOT · Anexos","Activos fijos","Retenciones","EE.FF. función y naturaleza"].concat(["ContaPlex · Contabilidad cloud","GestiónPlex · Inventarios","Facturación Electrónica","SIRE · RCE · RVIE","PLE · Libros electrónicos","Kárdex valorizado","Multi-almacén","POS · Restaurante","DAOT · Anexos","Activos fijos","Retenciones","EE.FF. función y naturaleza"]).map(item => (
        <span style="font-family:var(--font-mono); font-size:13px; letter-spacing:.04em; color:var(--ink-500); font-weight:500; display:inline-flex; align-items:center; gap:10px">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold-500)" stroke-width="2.5"><path d="M12 2 L14 10 L22 12 L14 14 L12 22 L10 14 L2 12 L10 10 Z"/></svg>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>

<!-- Strip de valor: badges institucionales -->
<section class="section-navy" style="padding:56px 0">
  <div class="container">
    <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:32px" data-anim="stagger">
      {hero.metricsStrip.map((m: any) => (
        <div style="text-align:center">
          <div style="font-size:clamp(24px, 3.2vw, 34px); font-weight:800; letter-spacing:-0.02em;" class="gold-text">{m.text}</div>
          <div style="font-size:13px; color:rgba(255,255,255,.72); margin-top:8px; font-weight:500; line-height:1.4">{m.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Métricas de impacto reales (Codeplex documentadas) -->
<section style="padding:80px 0; background:var(--bg-alt); border-bottom:1px solid var(--ink-200); position:relative; overflow:hidden">
  <DotPattern width={22} height={22} cr={1} color="color-mix(in srgb, var(--navy-700) 14%, transparent)" />
  <div class="container" style="position:relative">
    <div style="text-align:center; margin-bottom:48px" data-anim="reveal-up">
      <div class="eyebrow" style="color:var(--gold-700);">Resultados documentados</div>
      <h2 style="margin-top:8px;">Lo que mejora cuando<br/><span class="gradient-text">implementas Codeplex</span></h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:24px" data-anim="stagger">
      <div class="metric-card">
        <div class="metric-num" data-counter="40" data-counter-suffix="%">0%</div>
        <div class="metric-label">menos tiempo en cierre contable mensual</div>
      </div>
      <div class="metric-card">
        <div class="metric-num" data-counter="35" data-counter-suffix="%">0%</div>
        <div class="metric-label">reducción en errores de facturación</div>
      </div>
      <div class="metric-card">
        <div class="metric-num" data-counter="70" data-counter-suffix="%">0%</div>
        <div class="metric-label">más rápido el envío de libros SUNAT</div>
      </div>
      <div class="metric-card">
        <div class="metric-num" data-counter="60" data-counter-suffix="%">0%</div>
        <div class="metric-label">menos tiempo en conteos de inventario</div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 820px) {
    .section-navy > .container > div { grid-template-columns: repeat(2, 1fr) !important; gap: 24px !important; }
  }
  @media (max-width: 480px) {
    .section-navy > .container > div { grid-template-columns: 1fr !important; }
  }

  .metric-card {
    text-align:center; padding:32px 20px; border-radius:14px;
    background:var(--bg-card); border:1px solid var(--ink-200);
    transition:border-color .4s ease, transform .4s ease;
  }
  .metric-card:hover {
    border-color:color-mix(in srgb, var(--gold-500) 35%, var(--ink-200));
    transform:translateY(-2px);
  }
  .metric-num {
    font-size:clamp(40px, 5vw, 54px); font-weight:700; letter-spacing:-0.03em;
    color:var(--ink-900); line-height:1;
  }
  :global(html.dark) .metric-num { color: var(--gold-400); }
  .metric-label {
    font-size:13px; color:var(--ink-500); margin-top:12px;
    line-height:1.5; font-weight:500;
  }
  @media (max-width: 820px) {
    section[style*="border-bottom:1px solid var(--ink-200)"] > .container > div:last-child {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>
