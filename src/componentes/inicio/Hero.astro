---
import DotPattern from '@componentes/ui/mui/DotPattern.astro';
interface Props {
  hero: any;
}
const { hero } = Astro.props;
const heroVideo = "https://videos.pexels.com/video-files/8419153/8419153-uhd_2560_1440_25fps.mp4";
---
<section class="hero hero-v2">
  <!-- Background ambiental -->
  <video class="hero-video" autoplay muted loop playsinline preload="none">
    <source src={heroVideo} type="video/mp4" />
  </video>
  <div class="hero-bg"></div>
  <DotPattern width={28} height={28} cr={1} color="color-mix(in srgb, var(--gold-500) 18%, transparent)" />

  <div class="container">
    <div class="hero-grid-v2">
      <!-- Columna izquierda: copy -->
      <div class="hero-copy">
        <div class="row" style="gap:8px; margin-bottom:22px" data-anim="reveal-up">
          <span class="badge badge-pop">{hero.badgePartner}</span>
          <span class="badge">{hero.badgeSunat}</span>
        </div>

        <h1 data-anim="hero-title">
          {hero.tituloPre}<span class="gradient-text">{hero.tituloGradient}</span>{hero.tituloPost}
        </h1>

        <!-- Verticales rápidas: lo que SOMOS, en una línea -->
        <div class="verticales-tags" data-anim="reveal-up">
          {hero.verticales.map((v: any) => (
            <span class="vt-pill"><span class="vt-dot"></span>{v.label}</span>
          ))}
        </div>

        <p class="hero-desc" data-anim="reveal-up" set:html={hero.descripcion}></p>

        <div class="row" style="margin-top:30px; gap:12px" data-anim="reveal-up">
          <a class="btn btn-primary btn-lg btn-shine" href="#contacto">
            {hero.ctaPrimario}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a class="btn btn-outline btn-lg" href="#planes">{hero.ctaSecundario}</a>
        </div>

        <div class="hero-bullets" data-anim="stagger">
          {hero.bullets.map((b: string) => (
            <div class="hero-bullet">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold-500)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {b}
            </div>
          ))}
        </div>
      </div>

      <!-- Columna derecha: showcase de verticales (auto-cycle) -->
      <div class="hero-showcase" data-anim="reveal-right" aria-label="Sectores que atendemos">
        {hero.verticales.map((v: any, i: number) => (
          <div
            class={`shc-slide ${i === 0 ? 'active' : ''}`}
            data-shc-slide
            data-index={i}
            style={`background-image: linear-gradient(180deg, rgba(4,26,46,.15) 0%, rgba(4,26,46,.85) 100%), url('${v.img}');`}
          >
            <div class="shc-frame">
              <div class="shc-num">{String(i+1).padStart(2,'0')} / {String(hero.verticales.length).padStart(2,'0')}</div>
              <div class="shc-label">{v.label}</div>
              <div class="shc-sub">{v.sub}</div>
            </div>
          </div>
        ))}
        <!-- Dots indicador -->
        <div class="shc-dots">
          {hero.verticales.map((_v: any, i: number) => (
            <button type="button" class={`shc-dot ${i === 0 ? 'active' : ''}`} data-shc-dot data-index={i} aria-label={`Ver vertical ${i+1}`}></button>
          ))}
        </div>

        <!-- Custom cursor para navegación prev/next (solo desktop con pointer:fine) -->
        <div class="shc-cursor" data-shc-cursor aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Marquee: módulos reales de la suite Codeplex -->
<section style="padding:28px 0; background:var(--bg-alt); border-top:1px solid var(--ink-200); border-bottom:1px solid var(--ink-200)">
  <div class="marquee">
    <div class="marquee-track">
      {hero.marqueeItems.concat(hero.marqueeItems).map((item: string) => (
        <span style="font-family:var(--font-mono); font-size:13px; letter-spacing:.04em; color:var(--ink-500); font-weight:500; display:inline-flex; align-items:center; gap:10px">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold-500)" stroke-width="2.5"><path d="M12 2 L14 10 L22 12 L14 14 L12 22 L10 14 L2 12 L10 10 Z"/></svg>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>

<!-- Strip de valor: badges institucionales -->
<section class="section-navy" style="padding:56px 0">
  <div class="container">
    <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:32px" data-anim="stagger">
      {hero.metricsStrip.map((m: any) => (
        <div style="text-align:center">
          <div style="font-size:clamp(24px, 3.2vw, 34px); font-weight:800; letter-spacing:-0.02em;" class="gold-text">{m.text}</div>
          <div style="font-size:13px; color:rgba(255,255,255,.72); margin-top:8px; font-weight:500; line-height:1.4">{m.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Métricas de impacto reales (Codeplex documentadas) -->
<section style="padding:80px 0; background:var(--bg-alt); border-bottom:1px solid var(--ink-200); position:relative; overflow:hidden">
  <DotPattern width={22} height={22} cr={1} color="color-mix(in srgb, var(--navy-700) 14%, transparent)" />
  <div class="container" style="position:relative">
    <div style="text-align:center; margin-bottom:48px" data-anim="reveal-up">
      <div class="eyebrow" style="color:var(--gold-700);">{hero.impactSection.eyebrow}</div>
      <h2 style="margin-top:8px;">{hero.impactSection.tituloPre}<br/><span class="gradient-text">{hero.impactSection.tituloGradient}</span></h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:24px" data-anim="stagger">
      {hero.impactSection.metrics.map((m: any) => (
        <div class="metric-card">
          <div class="metric-num" data-counter={m.value} data-counter-suffix={m.suffix}>0{m.suffix}</div>
          <div class="metric-label">{m.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero-v2 { padding-top: 56px; padding-bottom: 56px; }
  .hero-grid-v2 {
    display: grid; grid-template-columns: 1.05fr 1fr;
    gap: 56px; align-items: center;
    position: relative; z-index: 2;
  }
  @media (max-width: 1024px) {
    .hero-grid-v2 { grid-template-columns: 1fr; gap: 40px; }
  }

  .hero-copy h1 {
    font-size: clamp(38px, 5.4vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 6px 0 18px;
  }
  .hero-desc {
    font-size: 17px;
    margin-top: 18px;
    max-width: 540px;
    color: var(--ink-500);
    line-height: 1.65;
  }
  .hero-bullets {
    margin-top: 30px;
    display: flex; flex-wrap: wrap; gap: 22px;
    font-size: 13px; color: var(--ink-500);
  }
  .hero-bullet { display: flex; align-items: center; gap: 6px; }

  /* Verticales como pills justo debajo del título — clave del 3-second test */
  .verticales-tags {
    display: flex; flex-wrap: wrap; gap: 8px;
    margin: 8px 0 4px;
  }
  .vt-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px; border-radius: 999px;
    background: color-mix(in srgb, var(--gold-500) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--gold-500) 28%, transparent);
    color: var(--ink-900); font-size: 13px; font-weight: 600;
    letter-spacing: 0.005em;
  }
  .vt-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold-700);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--gold-500) 25%, transparent);
  }
  :global(html.dark) .vt-pill {
    background: color-mix(in srgb, var(--gold-500) 8%, transparent);
    color: rgba(255,255,255,.92);
    border-color: color-mix(in srgb, var(--gold-500) 35%, transparent);
  }

  /* ===== Showcase auto-cycle ===== */
  .hero-showcase {
    position: relative;
    aspect-ratio: 4 / 5;
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
    border-radius: 24px;
    overflow: hidden;
    box-shadow:
      0 40px 70px -25px rgba(4,26,46,.5),
      0 0 0 1px rgba(255,255,255,.04);
    isolation: isolate;
  }
  /* Solo desktop con mouse fino: ocultar cursor del sistema sobre el showcase */
  @media (pointer: fine) {
    .hero-showcase { cursor: none; }
    .hero-showcase .shc-dot { cursor: pointer; }
  }
  .shc-slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0;
    transform: scale(1.06);
    transition: opacity .9s ease, transform 6s ease;
    will-change: opacity, transform;
    display: flex; align-items: flex-end;
  }
  .shc-slide.active {
    opacity: 1;
    transform: scale(1);
  }
  .shc-frame {
    width: 100%;
    padding: 28px 28px 56px;
    color: white;
    transform: translateY(8px);
    opacity: 0;
    transition: opacity .6s ease .15s, transform .6s ease .15s;
  }
  .shc-slide.active .shc-frame {
    opacity: 1;
    transform: translateY(0);
  }
  .shc-num {
    font-family: var(--font-mono);
    font-size: 12px; font-weight: 600;
    color: var(--gold-400);
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    text-transform: uppercase;
  }
  .shc-label {
    font-size: clamp(28px, 3.4vw, 38px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: white;
  }
  .shc-sub {
    font-size: 14px;
    color: rgba(255,255,255,.78);
    margin-top: 8px;
    line-height: 1.5;
    max-width: 90%;
  }

  .shc-dots {
    position: absolute; bottom: 18px; left: 28px;
    display: flex; gap: 6px;
    z-index: 3;
  }
  .shc-dot {
    width: 22px; height: 4px;
    border-radius: 2px;
    background: rgba(255,255,255,.28);
    border: none;
    cursor: pointer;
    transition: background .3s, width .3s;
    padding: 0;
  }
  .shc-dot.active {
    background: var(--gold-500);
    width: 36px;
  }
  .shc-dot:hover { background: rgba(255,255,255,.6); }
  .shc-dot.active:hover { background: var(--gold-500); }

  /* ===== Custom cursor sobre el showcase ===== */
  .shc-cursor {
    position: absolute;
    top: 0; left: 0;
    width: 64px; height: 64px;
    border-radius: 50%;
    background: rgba(255,255,255,0.14);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255,255,255,0.45);
    display: grid; place-items: center;
    color: white;
    pointer-events: none; /* deja pasar clicks al showcase */
    z-index: 4;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    transition: opacity .2s ease, transform .25s cubic-bezier(.16,1,.3,1);
    box-shadow: 0 8px 24px -10px rgba(0,0,0,.4);
  }
  .shc-cursor.visible {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
  .shc-cursor svg {
    transition: transform .25s cubic-bezier(.16,1,.3,1);
  }
  .shc-cursor.left svg { transform: rotate(180deg); }
  /* Pequeña animación al click */
  .shc-cursor.click {
    transform: translate(-50%, -50%) scale(0.85);
    background: rgba(255,255,255,0.28);
  }
  /* Touch / coarse pointer: nunca mostrar custom cursor */
  @media (pointer: coarse) {
    .shc-cursor { display: none !important; }
  }

  @media (max-width: 1024px) {
    .hero-showcase { max-width: 100%; aspect-ratio: 16 / 10; }
  }
  @media (max-width: 768px) {
    .hero-showcase { aspect-ratio: 4 / 3; }
  }
  @media (max-width: 600px) {
    .hero-showcase { aspect-ratio: 4 / 3.2; border-radius: 18px; }
    .shc-frame { padding: 20px 20px 48px; }
    .shc-label { font-size: 26px; }
    .verticales-tags { gap: 6px; }
    .vt-pill { font-size: 12px; padding: 5px 10px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .shc-slide, .shc-frame, .shc-cursor { transition: opacity .3s ease; transform: none; }
  }
</style>

<script is:inline>
  (function () {
    function setupShowcase() {
      const root = document.querySelector('.hero-showcase');
      if (!root || root.__wired) return;
      root.__wired = true;
      const slides = Array.from(root.querySelectorAll('[data-shc-slide]'));
      const dots = Array.from(root.querySelectorAll('[data-shc-dot]'));
      const cursor = root.querySelector('[data-shc-cursor]');
      if (!slides.length) return;

      let current = 0;
      const total = slides.length;
      const INTERVAL = 4200;
      let timer = null;

      function go(idx) {
        current = ((idx % total) + total) % total;
        slides.forEach((s, i) => s.classList.toggle('active', i === current));
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
      }
      function next() { go(current + 1); }
      function prev() { go(current - 1); }
      function start() {
        stop();
        timer = setInterval(next, INTERVAL);
      }
      function stop() { if (timer) { clearInterval(timer); timer = null; } }

      // Dots: click directo. stopPropagation para no disparar prev/next del showcase.
      dots.forEach((d, i) => {
        d.addEventListener('click', (e) => {
          e.stopPropagation();
          go(i); start();
        });
      });

      // Auto-pausa al hover y reanuda al salir
      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', () => {
        if (cursor) cursor.classList.remove('visible');
        start();
      });

      // Pausa cuando la pestaña no está visible
      document.addEventListener('visibilitychange', () => {
        document.hidden ? stop() : start();
      });

      // Custom cursor: solo si el dispositivo tiene puntero fino (mouse).
      const hasFinePointer = window.matchMedia('(pointer: fine)').matches;
      if (hasFinePointer && cursor) {
        let rect = root.getBoundingClientRect();
        // Recalcula rect en resize/scroll para mantener precisión
        const updateRect = () => { rect = root.getBoundingClientRect(); };
        window.addEventListener('resize', updateRect, { passive: true });
        window.addEventListener('scroll', updateRect, { passive: true });

        root.addEventListener('mousemove', (e) => {
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          cursor.style.left = x + 'px';
          cursor.style.top = y + 'px';
          const isLeft = x < rect.width / 2;
          cursor.classList.toggle('left', isLeft);
          cursor.classList.toggle('right', !isLeft);
        });
        root.addEventListener('mouseenter', () => {
          updateRect();
          cursor.classList.add('visible');
        });
        // mouseleave ya quita .visible (arriba)
      }

      // Click sobre el showcase: prev (lado izquierdo) o next (lado derecho).
      // Excluye los dots (ellos manejan su click propio con stopPropagation).
      root.addEventListener('click', (e) => {
        if (e.target.closest('[data-shc-dot]')) return;
        const r = root.getBoundingClientRect();
        const x = e.clientX - r.left;
        // Animación pequeña del cursor al clickear
        if (cursor) {
          cursor.classList.add('click');
          setTimeout(() => cursor.classList.remove('click'), 200);
        }
        if (x < r.width / 2) prev(); else next();
        start();
      });

      start();
    }
    setupShowcase();
    document.addEventListener('astro:page-load', setupShowcase);
  })();
</script>
