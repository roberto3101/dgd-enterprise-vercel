---
import BentoGrid from '@componentes/ui/mui/BentoGrid.astro';
import BentoCard from '@componentes/ui/mui/BentoCard.astro';
import DotPattern from '@componentes/ui/mui/DotPattern.astro';
interface Props {
  productos: any;
}
const { productos } = Astro.props;

// Mapeo de iconos por slug (Lucide-style limpios)
const iconos: Record<string, string> = {
  contaplex: '<rect x="3" y="4" width="18" height="16" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="9" y1="4" x2="9" y2="20"/>',
  gestionplex: '<path d="M21 16V8a2 2 0 0 0-1-1.7l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.7l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.3 7 12 12 20.7 7"/><line x1="12" y1="22" x2="12" y2="12"/>',
  'facturacion-sunat': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/>',
};

// Bento: card principal ocupa 2 columnas, las demás 1
const cardStyles = [
  'grid-column: span 2 / span 2;',
  '',
  'grid-column: span 3 / span 3;',
];
---
<section id="productos">
  <div class="container">
    <div class="section-header" data-anim="reveal-up">
      <div class="eyebrow">{productos.eyebrow}</div>
      <h2>{productos.titulo}</h2>
      <p>{productos.descripcion}</p>
    </div>

    <BentoGrid className="productos-bento">
      {productos.items.map((p: any, i: number) => (
        <BentoCard
          name={p.nombre}
          description={p.tagline}
          href={`/es/productos/${p.slug}/`}
          cta={p.cta}
          style={cardStyles[i]}
        >
          <div slot="background" class={`producto-bg producto-bg-${i}`} style={`--accent:${p.color}`}>
            <DotPattern width={20} height={20} cr={1} />
            <div class="producto-orb" style={`background:radial-gradient(circle, color-mix(in srgb, ${p.color} 35%, transparent), transparent 65%);`}></div>
          </div>
          <svg slot="icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconos[p.slug] || ''}></svg>
        </BentoCard>
      ))}
    </BentoGrid>

    <!-- Bullets agrupados bajo los productos (lo que antes era lista en cada card) -->
    <div class="productos-bullets" data-anim="stagger">
      {productos.items.map((p: any) => (
        <div class="productos-bullet-group">
          <div class="pbg-head" style={`--accent:${p.color}`}>
            <span class="pbg-dot"></span>
            <span class="pbg-name">{p.nombre}</span>
          </div>
          <ul class="pbg-list">
            {p.bullets.map((b: string) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={p.color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {b}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .productos-bento :global(.col-wide) { grid-column: span 2 / span 2; }
  .productos-bento :global(.col-normal) { grid-column: span 1 / span 1; }
  @media (max-width: 900px) {
    .productos-bento :global(.col-wide),
    .productos-bento :global(.col-normal) { grid-column: span 1 / span 1; }
  }

  .producto-bg {
    position: absolute; inset: 0; overflow: hidden; opacity: .55;
    color: var(--ink-300);
  }
  .producto-bg-0 .producto-orb {
    position: absolute; width: 380px; height: 380px; right: -120px; top: -120px;
  }
  .producto-bg-1 .producto-orb,
  .producto-bg-2 .producto-orb {
    position: absolute; width: 260px; height: 260px; right: -80px; bottom: -80px;
  }

  .productos-bullets {
    margin-top: 32px;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
  }
  @media (max-width: 900px) { .productos-bullets { grid-template-columns: 1fr; } }

  .productos-bullet-group {
    padding: 20px 22px; border-radius: 12px;
    background: var(--bg-alt);
    border: 1px solid var(--ink-200);
  }
  .pbg-head {
    display: flex; align-items: center; gap: 10px;
    font-weight: 700; font-size: 14px; color: var(--ink-900);
    padding-bottom: 10px; margin-bottom: 12px;
    border-bottom: 1px solid var(--ink-200);
  }
  .pbg-dot {
    width: 8px; height: 8px; border-radius: 2px; background: var(--accent);
  }
  .pbg-list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 8px;
    font-size: 13px; color: var(--ink-700);
  }
  .pbg-list li { display: flex; gap: 8px; align-items: flex-start; line-height: 1.5; }
</style>
