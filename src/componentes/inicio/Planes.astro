---
import Icon from '@componentes/ui/Icon.astro';
import type { Idioma } from '@helpers/idiomas';
interface Props {
  planes: any;
  idioma: Idioma;
}
const { planes, idioma } = Astro.props;
const planesHref = `/${idioma}/planes/`;
---
<section id="planes" class="section-alt">
  <div class="container">
    <div class="section-header" data-anim="reveal-up">
      <div class="eyebrow">{planes.eyebrow}</div>
      <h2>{planes.titulo}</h2>
      <p>{planes.descripcion}</p>
    </div>

    <div class="planes-preview" data-anim="stagger">
      {planes.productos.map((p: any) => (
        <div class={`plan-prev ${p.popular ? 'popular' : ''}`}>
          {p.popular && <span class="badge plan-prev-pop">{planes.popularBadge}</span>}
          <div class="plan-prev-icon"><Icon name={p.icon} size={22} /></div>
          <div class="plan-prev-eyebrow">{p.tagline}</div>
          <h3 class="plan-prev-name">{p.producto}</h3>

          <div class="plan-prev-price">
            <span class="pp-from">{planes.desdeText}</span>
            {p.desdeLabel ? (
              <span class="pp-free">{p.desdeLabel}</span>
            ) : (
              <>
                <span class="pp-cur">{planes.moneda}</span>
                <span class="pp-num">{p.desde}</span>
                <span class="pp-per">{planes.perMes}</span>
              </>
            )}
          </div>

          <ul class="plan-prev-list">
            {p.highlights.map((h: string) => (
              <li>
                <Icon name="check" size={14} stroke={2.5} />
                <span>{h}</span>
              </li>
            ))}
          </ul>

          <a class={p.popular ? 'btn btn-primary' : 'btn btn-outline'}
             href={`${planesHref}#fam-${p.slug}`}
             style="width:100%; justify-content:center; margin-top:auto;">
            {planes.ctaVer}
            <Icon name="arrow" size={14} stroke={2.5} />
          </a>
        </div>
      ))}
    </div>

    <div class="planes-cta-row">
      <a class="btn btn-dark btn-lg" href={planesHref}>
        {planes.ctaVerTodos}
        <Icon name="arrow" size={16} stroke={2.5} />
      </a>
    </div>
  </div>
</section>

<style>
  .planes-preview {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 20px; margin-bottom: 32px;
    align-items: stretch;
  }
  @media (max-width: 980px) { .planes-preview { grid-template-columns: 1fr; } }

  .plan-prev {
    position: relative;
    padding: 28px 26px;
    border-radius: 18px;
    background: var(--bg);
    border: 1px solid var(--ink-200);
    box-shadow: var(--shadow-sm);
    display: flex; flex-direction: column;
  }
  .plan-prev.popular {
    background: linear-gradient(180deg, var(--brand-primary), #123558);
    color: white;
    border-color: rgba(255,255,255,.15);
    box-shadow: var(--shadow-xl);
    transform: translateY(-6px);
  }
  @media (max-width: 980px) { .plan-prev.popular { transform: none; } }

  .plan-prev-pop {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    background: var(--brand-accent); color: var(--ink-900);
    padding: 4px 12px; border-radius: 999px;
    font-size: 11px; font-weight: 700; letter-spacing: .04em;
  }
  .plan-prev-icon {
    width: 48px; height: 48px; border-radius: 12px;
    background: color-mix(in srgb, var(--brand-accent) 16%, transparent);
    color: var(--brand-accent-2);
    display: grid; place-items: center; margin-bottom: 16px;
  }
  .plan-prev.popular .plan-prev-icon {
    background: rgba(255,255,255,.12);
    color: var(--brand-accent);
  }
  .plan-prev-eyebrow {
    font-size: 12px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--brand-accent-2); margin-bottom: 6px;
  }
  .plan-prev.popular .plan-prev-eyebrow { color: var(--brand-accent); }
  .plan-prev-name { font-size: 22px; margin-bottom: 14px; letter-spacing: -0.01em; }

  .plan-prev-price {
    display: flex; align-items: baseline; gap: 6px;
    margin-bottom: 18px; flex-wrap: wrap;
  }
  .pp-from {
    font-size: 12px; color: var(--ink-500); text-transform: uppercase;
    letter-spacing: .06em; font-weight: 600;
  }
  .plan-prev.popular .pp-from { color: rgba(255,255,255,.7); }
  .pp-cur { font-size: 16px; font-weight: 600; opacity: .7; margin-left: 4px; }
  .pp-num { font-size: 36px; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
  .pp-per { font-size: 13px; color: var(--ink-500); }
  .plan-prev.popular .pp-per { color: rgba(255,255,255,.7); }
  .pp-free {
    font-size: 24px; font-weight: 800; color: var(--brand-accent-2);
    margin-left: 4px;
  }
  .plan-prev.popular .pp-free { color: var(--brand-accent); }

  .plan-prev-list {
    list-style: none; display: flex; flex-direction: column;
    gap: 10px; margin: 0 0 22px; padding: 0;
  }
  .plan-prev-list li {
    display: flex; gap: 8px; font-size: 13.5px;
    color: var(--ink-700); align-items: flex-start;
  }
  .plan-prev.popular .plan-prev-list li { color: rgba(255,255,255,.85); }
  .plan-prev-list svg {
    color: var(--brand-accent-2); flex-shrink: 0; margin-top: 3px;
  }
  .plan-prev.popular .plan-prev-list svg { color: var(--brand-accent); }

  .planes-cta-row { text-align: center; margin-top: 8px; }
</style>
