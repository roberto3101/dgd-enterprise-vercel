---
interface Props {
  cta: any;
}
const { cta } = Astro.props;
const f = cta.formulario;
---
<section id="contacto" style="padding:72px 0">
  <div class="container">
    <div style="border-radius:var(--radius-xl); background:linear-gradient(135deg, #041A2E 0%, #072540 60%, #0E3A5F 140%); padding:clamp(40px, 6vw, 72px); color:white; position:relative; overflow:hidden">
      <img src="/imagenes/abstract-navy-gold.webp" alt="" aria-hidden="true" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:.35; mix-blend-mode:screen; pointer-events:none" loading="lazy" />
      <div style="position:absolute; inset:0; background:linear-gradient(135deg, rgba(4,26,46,.55) 0%, rgba(7,37,64,.4) 50%, rgba(14,58,95,.2) 100%); pointer-events:none"></div>
      <div style="position:absolute; right:-100px; top:-100px; width:400px; height:400px; border-radius:50%; background:radial-gradient(circle, rgba(212,175,55,.25), transparent 70%); pointer-events:none"></div>
      <div style="position:relative; display:grid; grid-template-columns:1fr 1fr; gap:56px; align-items:center">
        <div data-anim="reveal-left">
          <h2 style="color:white">{cta.titulo}</h2>
          <p style="color:rgba(255,255,255,.82); margin-top:14px; font-size:17px; line-height:1.6">{cta.descripcion}</p>
          <div style="margin-top:28px; display:flex; flex-direction:column; gap:14px; color:rgba(255,255,255,.85); font-size:14px" data-anim="stagger">
            {cta.bullets.map((b: string) => (
              <div style="display:flex; gap:10px; align-items:center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--brand-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {b}
              </div>
            ))}
          </div>
        </div>
        <form data-anim="reveal-right" style="background:rgba(255,255,255,.08); backdrop-filter:blur(12px); border-radius:18px; padding:28px; border:1px solid rgba(255,255,255,.15)">
          <h3 style="color:white; font-size:18px; margin-bottom:18px">{f.titulo}</h3>
          <div style="display:flex; flex-direction:column; gap:12px">
            <input required placeholder={f.nombre} class="input" style="background:rgba(255,255,255,.95);color:#0A1628" />
            <input required type="email" placeholder={f.email} class="input" style="background:rgba(255,255,255,.95);color:#0A1628" />
            <input placeholder={f.whatsapp} class="input" style="background:rgba(255,255,255,.95);color:#0A1628" />
            <select class="select" style="background:rgba(255,255,255,.95);color:#0A1628">
              {f.productos.map((p: string) => <option>{p}</option>)}
            </select>
            <button type="submit" class="btn btn-primary btn-lg" style="justify-content:center; width:100%; margin-top:6px">
              {f.cta}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
