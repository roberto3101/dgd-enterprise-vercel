---
interface Props {
  casos: any;
}
const { casos } = Astro.props;
---
<section id="casos">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">{casos.eyebrow}</div>
      <h2>{casos.titulo}</h2>
      <p>{casos.descripcion}</p>
    </div>
    <div class="grid-3">
      {casos.items.map((c: any) => (
        <article class="card card-hover" style="border-radius:18px; overflow:hidden; display:flex; flex-direction:column">
          <div style={`padding:18px 20px; background:color-mix(in srgb, ${c.color} 10%, transparent); border-bottom:1px solid var(--ink-100); display:flex; align-items:center; justify-content:space-between`}>
            <span style={`font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:${c.color}`}>{c.industria}</span>
            <span class="badge" style={`background:color-mix(in srgb, ${c.color} 18%, transparent); color:${c.color}`}>{c.tag}</span>
          </div>
          <div style="padding:22px; display:flex; flex-direction:column; gap:10px; flex:1">
            <h3 style="font-size:18px">{c.empresa}</h3>
            <div style="font-size:13px; font-weight:600; color:var(--brand-accent-2)">{c.kpi}</div>
            <p style="font-size:14px; color:var(--ink-500); line-height:1.6; flex:1">{c.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
