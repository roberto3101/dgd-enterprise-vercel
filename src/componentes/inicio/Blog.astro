---
interface Props {
  blog: any;
}
const { blog } = Astro.props;
---
<section id="blog" class="section-alt">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">{blog.eyebrow}</div>
      <h2>{blog.titulo}</h2>
      <p>{blog.descripcion}</p>
    </div>
    <div style="max-width:560px; margin:0 auto; padding:40px; border-radius:20px; background:var(--bg); border:1px solid var(--ink-200); box-shadow:var(--shadow); text-align:center">
      <div style="font-size:40px; margin-bottom:14px">✍️</div>
      <p style="font-size:15px; color:var(--ink-500); margin-bottom:24px">{blog.placeholder}</p>
      <form style="display:flex; gap:8px; flex-wrap:wrap">
        <input class="input" type="email" placeholder={blog.emailPlaceholder} required style="flex:1; min-width:200px" />
        <button class="btn btn-primary" type="submit">{blog.ctaSuscribir}</button>
      </form>
    </div>
  </div>
</section>
