---
/**
 * SeoHead — motor SEO completo.
 *
 * Inyecta:
 *  - Meta básicos (title, description, keywords, canonical, robots)
 *  - Open Graph + Twitter Cards
 *  - hreflang alternates (ES ↔ EN)
 *  - JSON-LD sitewide: Organization + LocalBusiness + WebSite
 *  - JSON-LD por página (opcional): Product / Article / BreadcrumbList / FAQPage / Service
 */
import type { Idioma } from '@helpers/idiomas';

interface Props {
  idioma: Idioma;
  seoData: {
    titulo: string;
    descripcion: string;
    ogImage?: string;
    ogImageAlt?: string;
    twitterHandle?: string;
    keywords?: string;
  };
  /** Tipo de página para schema principal extra */
  pageType?: 'website' | 'product' | 'article';
  /** Datos del producto si pageType === 'product' */
  productData?: {
    name: string;
    description: string;
    image: string;
    brand?: string;
    offers?: Array<{ name: string; price: string; priceCurrency?: string; description?: string }>;
  };
  /** Datos del artículo si pageType === 'article' */
  articleData?: {
    headline: string;
    description: string;
    image: string;
    datePublished: string;
    dateModified?: string;
    author: { name: string; jobTitle?: string };
    section?: string;
    keywords?: string;
    wordCount?: number;
  };
  /** BreadcrumbList */
  breadcrumbs?: Array<{ name: string; url: string }>;
  /** FAQ items */
  faqs?: Array<{ question: string; answer: string }>;
  /** Schema arbitrario adicional */
  schemaExtra?: Record<string, any>;
}

const {
  idioma, seoData, pageType = 'website',
  productData, articleData, breadcrumbs, faqs, schemaExtra,
} = Astro.props;
const SITE = 'https://dgd-enterprise.pe';

// URL canónica + alternates por idioma
const pathname = Astro.url.pathname;
const canonical = new URL(pathname, SITE).toString();
const hrefEs = new URL(pathname.replace(/^\/en\//, '/es/'), SITE).toString();
const hrefEn = new URL(pathname.replace(/^\/es\//, '/en/'), SITE).toString();

const ogImage = new URL(seoData.ogImage || '/logo.png', SITE).toString();
const ogLocale = idioma === 'es' ? 'es_PE' : 'en_US';
const ogLocaleAlt = idioma === 'es' ? 'en_US' : 'es_PE';
const ogType = pageType === 'article' ? 'article' : (pageType === 'product' ? 'product' : 'website');

// ============== JSON-LD: Organization (sitewide) ==============
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE}/#organization`,
  name: 'Grupo DGD',
  alternateName: 'DGD Enterprise',
  url: SITE,
  logo: { '@type': 'ImageObject', url: `${SITE}/logo.png`, width: 400, height: 400 },
  description: seoData.descripcion,
  foundingDate: '2018',
  knowsAbout: [
    'ContaPlex', 'GestiónPlex', 'Facturación Electrónica SUNAT',
    'PLE', 'SIRE', 'POS', 'Inventarios', 'Contabilidad cloud',
    'Software para grifos', 'Software para restaurantes',
  ],
  areaServed: { '@type': 'Country', name: 'Peru' },
  sameAs: [
    'https://www.linkedin.com/company/grupo-dgd',
    'https://www.facebook.com/grupodgd',
    'https://www.instagram.com/grupodgd',
  ],
  contactPoint: [{
    '@type': 'ContactPoint',
    telephone: '+51-936-343-607',
    email: 'ventas@codeplex.pe',
    contactType: 'sales',
    areaServed: 'PE',
    availableLanguage: ['Spanish', 'English'],
  }],
};

// ============== JSON-LD: LocalBusiness (CRÍTICO para SEO local Lima/Perú) ==============
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${SITE}/#localbusiness`,
  name: 'Grupo DGD',
  image: `${SITE}/logo.png`,
  url: SITE,
  telephone: '+51-936-343-607',
  email: 'ventas@codeplex.pe',
  priceRange: 'S/. 50 - S/. 950',
  description: seoData.descripcion,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Av. Los Próceres Mza. G3 Lote 11',
    addressLocality: 'Los Olivos',
    addressRegion: 'Lima',
    postalCode: '15304',
    addressCountry: 'PE',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -11.9858,
    longitude: -77.0712,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00', closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '08:00', closes: '14:00',
    },
  ],
  areaServed: { '@type': 'Country', name: 'Peru' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de implementación Codeplex',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Implementación ContaPlex' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Implementación GestiónPlex' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Facturación Electrónica SUNAT' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Capacitación contable' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Soporte técnico SUNAT' } },
    ],
  },
};

// ============== JSON-LD: WebSite ==============
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE}/#website`,
  name: 'Grupo DGD',
  url: SITE,
  inLanguage: idioma === 'es' ? 'es-PE' : 'en-US',
  publisher: { '@id': `${SITE}/#organization` },
};

// ============== JSON-LD: Product (per-page) ==============
let productSchema: any = null;
if (pageType === 'product' && productData) {
  productSchema = {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: productData.name,
    description: productData.description,
    image: new URL(productData.image, SITE).toString(),
    brand: { '@type': 'Brand', name: productData.brand || 'Codeplex Software' },
    manufacturer: { '@id': `${SITE}/#organization` },
    category: 'Business Software',
    offers: productData.offers && productData.offers.length > 0 ? {
      '@type': 'AggregateOffer',
      priceCurrency: 'PEN',
      lowPrice: Math.min(...productData.offers.map(o => parseFloat(o.price) || 0)),
      highPrice: Math.max(...productData.offers.map(o => parseFloat(o.price) || 0)),
      offerCount: productData.offers.length,
      offers: productData.offers.map(o => ({
        '@type': 'Offer',
        name: o.name,
        price: o.price,
        priceCurrency: o.priceCurrency || 'PEN',
        description: o.description,
        availability: 'https://schema.org/InStock',
        url: canonical,
        seller: { '@id': `${SITE}/#organization` },
      })),
    } : undefined,
  };
}

// ============== JSON-LD: Article (BlogPosting) per-page ==============
let articleSchema: any = null;
if (pageType === 'article' && articleData) {
  articleSchema = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    headline: articleData.headline,
    description: articleData.description,
    image: new URL(articleData.image, SITE).toString(),
    datePublished: articleData.datePublished,
    dateModified: articleData.dateModified || articleData.datePublished,
    author: {
      '@type': 'Person',
      name: articleData.author.name,
      jobTitle: articleData.author.jobTitle,
      worksFor: { '@id': `${SITE}/#organization` },
    },
    publisher: { '@id': `${SITE}/#organization` },
    articleSection: articleData.section,
    keywords: articleData.keywords,
    wordCount: articleData.wordCount,
    inLanguage: idioma === 'es' ? 'es-PE' : 'en-US',
  };
}

// ============== JSON-LD: BreadcrumbList ==============
let breadcrumbSchema: any = null;
if (breadcrumbs && breadcrumbs.length > 0) {
  breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      item: new URL(b.url, SITE).toString(),
    })),
  };
}

// ============== JSON-LD: FAQPage ==============
let faqSchema: any = null;
if (faqs && faqs.length > 0) {
  faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  };
}
---
<!-- Meta básicos -->
<title>{seoData.titulo}</title>
<meta name="description" content={seoData.descripcion} />
{seoData.keywords && <meta name="keywords" content={seoData.keywords} />}
<meta name="author" content="Grupo DGD" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />
<meta name="geo.region" content="PE-LIM" />
<meta name="geo.placename" content="Lima, Peru" />
<meta name="geo.position" content="-11.9858;-77.0712" />
<meta name="ICBM" content="-11.9858, -77.0712" />
<link rel="canonical" href={canonical} />

<!-- Alternates hreflang i18n -->
<link rel="alternate" hreflang="es-PE" href={hrefEs} />
<link rel="alternate" hreflang="en-US" href={hrefEn} />
<link rel="alternate" hreflang="x-default" href={hrefEs} />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Grupo DGD" />
<meta property="og:title" content={seoData.titulo} />
<meta property="og:description" content={seoData.descripcion} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={seoData.ogImageAlt || seoData.titulo} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlt} />

<!-- Article-specific OG (si aplica) -->
{articleData && <meta property="article:published_time" content={articleData.datePublished} />}
{articleData && articleData.dateModified && <meta property="article:modified_time" content={articleData.dateModified} />}
{articleData && <meta property="article:author" content={articleData.author.name} />}
{articleData && articleData.section && <meta property="article:section" content={articleData.section} />}

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
{seoData.twitterHandle && <meta name="twitter:site" content={seoData.twitterHandle} />}
{seoData.twitterHandle && <meta name="twitter:creator" content={seoData.twitterHandle} />}
<meta name="twitter:title" content={seoData.titulo} />
<meta name="twitter:description" content={seoData.descripcion} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={seoData.ogImageAlt || seoData.titulo} />

<!-- JSON-LD: Organization -->
<script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>

<!-- JSON-LD: LocalBusiness (Lima, Perú) -->
<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>

<!-- JSON-LD: WebSite -->
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>

<!-- JSON-LD: por página (Product / Article / Breadcrumbs / FAQ) -->
{productSchema && <script type="application/ld+json" set:html={JSON.stringify(productSchema)}></script>}
{articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>}
{breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>}
{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>}
{schemaExtra && <script type="application/ld+json" set:html={JSON.stringify(schemaExtra)}></script>}
