---
import Icon from '@componentes/ui/Icon.astro';
import CTAPanel from '@componentes/ui/CTAPanel.astro';
import PlanesFamilia from '@componentes/paginas/PlanesFamilia.astro';
import type { Idioma } from '@helpers/idiomas';
interface Props { datos: any; idioma: Idioma; }
const { datos, idioma } = Astro.props;
const contactoHref = `/${idioma}/contacto/`;
---
<section style="padding:72px 0 24px;">
  <div class="container" style="text-align:center;max-width:820px;">
    <div class="eyebrow">{datos.eyebrow}</div>
    <h1 style="margin-top:8px;">{datos.titulo}</h1>
    <p style="font-size:17px;color:var(--ink-500);margin-top:18px;line-height:1.6;">{datos.descripcion}</p>
    <div class="planes-meta">
      <span class="meta-pill"><Icon name="check" size={14} stroke={2.5} />{datos.incluyeIgv}</span>
      <span class="meta-pill"><Icon name="sync" size={14} />{datos.incluyeActualizaciones}</span>
    </div>
    <p class="planes-sectores">{datos.verBrochure}</p>
  </div>
</section>

<section style="padding:0 0 48px;">
  <div class="container">
    <div class="fam-nav">
      {datos.familias.map((f: any) => (
        <a class="fam-nav-link" href={`#fam-${f.slug}`}>
          <Icon name={f.icon} size={16} />
          <span>{f.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>

{datos.familias.map((f: any) => (
  <div id={`fam-${f.slug}`}>
    <PlanesFamilia familia={f} textos={datos} contactoHref={contactoHref} idioma={idioma} />
  </div>
))}

<CTAPanel titulo={datos.cta.titulo} descripcion={datos.cta.descripcion} ctaPrimario={datos.cta.primario} hrefPrimario={contactoHref} />

<style>
  .planes-meta { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-top: 22px; }
  .meta-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px; border-radius: 999px;
    background: color-mix(in srgb, var(--brand-accent) 14%, transparent);
    color: var(--ink-900); font-size: 13px; font-weight: 600;
  }
  .meta-pill svg { color: var(--brand-accent-2); }
  .planes-sectores { font-size: 12px; color: var(--ink-500); margin-top: 16px; letter-spacing: .04em; }

  .fam-nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; }
  .fam-nav-link {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 20px; border-radius: 999px;
    border: 1px solid var(--ink-200); background: var(--bg);
    color: var(--ink-700); font-weight: 600; font-size: 14px;
    transition: all .15s;
  }
  .fam-nav-link:hover { background: var(--ink-900); color: var(--bg); border-color: transparent; transform: translateY(-1px); }
</style>
