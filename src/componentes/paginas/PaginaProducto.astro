---
import Icon from '@componentes/ui/Icon.astro';
import SectionHeader from '@componentes/ui/SectionHeader.astro';
import FAQ from '@componentes/ui/FAQ.astro';
import CTAPanel from '@componentes/ui/CTAPanel.astro';
import DashMock from '@componentes/ui/DashMock.astro';
import type { Idioma } from '@helpers/idiomas';
interface Props { producto: any; idioma: Idioma; }
const { producto, idioma } = Astro.props;
const contactoHref = `/${idioma}/contacto/`;
const planesHref = `/${idioma}/planes/`;
const variant = producto.slug === 'gestionplex' ? 'gestionplex' : producto.slug === 'facturacion-sunat' ? 'facturacion' : 'contaplex';
---
<section class="hero" style="padding-bottom:48px;">
  <div class="hero-bg"></div>
  <div class="container" style="position:relative;">
    <div class="producto-hero-grid">
      <div>
        <div class="producto-badge">
          <div class="producto-badge-icon" style={`background:linear-gradient(135deg, ${producto.color}, color-mix(in srgb, ${producto.color} 60%, black));`}><Icon name={producto.icon} size={22} /></div>
          <div>
            <div class="producto-eyebrow">{producto.eyebrow}</div>
            <div style="font-size:20px;font-weight:800;">{producto.name}</div>
          </div>
        </div>
        <h1 style="font-size:clamp(2rem, 4vw, 3.2rem);">{producto.hero}</h1>
        <p style="font-size:18px;color:var(--ink-500);margin-top:20px;max-width:540px;line-height:1.6;">{producto.heroDesc}</p>
        <div class="row" style="margin-top:28px;gap:12px;">
          <a class="btn btn-primary btn-lg" href={contactoHref}>{producto.ctaPrimario} <Icon name="arrow" size={18} /></a>
          <a class="btn btn-outline btn-lg" href="#planes">{producto.ctaSecundario}</a>
        </div>
      </div>
      <div>
        <DashMock variant={variant} />
      </div>
    </div>
  </div>
</section>

<section class="section-alt">
  <div class="container">
    <SectionHeader eyebrow={producto.featuresEyebrow} titulo={producto.featuresTitulo} />
    <div class="features-grid">
      {producto.features.map((f: any) => (
        <div class="card" style="padding:22px;background:var(--bg);border-radius:16px;">
          <div class="feature-icon" style={`background:color-mix(in srgb, ${producto.color} 12%, transparent);color:${producto.color};`}>
            <Icon name={f.icon} size={20} />
          </div>
          <h3 style="font-size:15px;margin-bottom:6px;">{f.title}</h3>
          <p style="font-size:13px;color:var(--ink-500);line-height:1.5;">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section id="planes">
  <div class="container">
    <SectionHeader eyebrow={producto.plansEyebrow} titulo={producto.plansTitulo} descripcion={producto.plansDesc} />
    <div class="producto-planes" style={`grid-template-columns:repeat(${producto.plans.length},1fr);max-width:${producto.plans.length > 3 ? '1100px' : '900px'};`}>
      {producto.plans.map((plan: any) => (
        <div class={`prod-plan ${plan.popular ? 'popular' : ''}`}>
          {plan.popular && <span class="badge badge-pop prod-plan-pop">{idioma === 'es' ? 'MÁS POPULAR' : 'MOST POPULAR'}</span>}
          <div class="prod-plan-name">{plan.name}</div>
          <div class="prod-plan-price">
            <span style="font-size:42px;font-weight:800;letter-spacing:-0.03em;">S/{plan.price}</span>
            <span class="prod-plan-per">/{idioma === 'es' ? 'mes' : 'mo'}</span>
          </div>
          <div class="prod-plan-empresas">{plan.empresas}</div>
          <p class="prod-plan-desc">{plan.desc}</p>
          <ul class="prod-plan-features">
            {plan.features.map((f: string) => (
              <li><Icon name="check" size={16} stroke={2.5} /><span>{f}</span></li>
            ))}
          </ul>
          <a class={`btn ${plan.popular ? 'btn-primary' : 'btn-outline'}`} href={contactoHref} style="width:100%;justify-content:center;">
            {plan.popular ? (idioma === 'es' ? 'Solicitar demo' : 'Request demo') : (idioma === 'es' ? 'Elegir plan' : 'Choose plan')}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section-alt">
  <div class="container" style="max-width:820px;">
    <SectionHeader eyebrow={producto.faqEyebrow} titulo={producto.faqTitulo} />
    <FAQ items={producto.faq} />
  </div>
</section>

<CTAPanel
  titulo={producto.cta.titulo}
  descripcion={producto.cta.descripcion}
  ctaPrimario={producto.cta.primario}
  hrefPrimario={contactoHref}
  ctaSecundario={producto.cta.secundario}
  hrefSecundario={planesHref}
/>

<style>
  .producto-hero-grid { display:grid; grid-template-columns:1fr 1.1fr; gap:48px; align-items:center; }
  @media (max-width:900px) { .producto-hero-grid { grid-template-columns:1fr; } }
  .producto-badge { display:flex; align-items:center; gap:10px; margin-bottom:18px; }
  .producto-badge-icon {
    width:42px; height:42px; border-radius:12px; color:white;
    display:grid; place-items:center;
  }
  .producto-eyebrow {
    font-size:12px; color:var(--ink-500);
    text-transform:uppercase; letter-spacing:.08em; font-weight:600;
  }
  .features-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; }
  @media (max-width:960px) { .features-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:520px) { .features-grid { grid-template-columns:1fr; } }
  .feature-icon {
    width:40px; height:40px; border-radius:10px;
    display:grid; place-items:center; margin-bottom:14px;
  }
  .producto-planes { display:grid; gap:20px; margin:0 auto; }
  @media (max-width:960px) { .producto-planes { grid-template-columns:1fr !important; } }
  .prod-plan {
    padding:28px; border-radius:20px; background:var(--bg); color:inherit;
    border:1px solid var(--ink-200); position:relative; box-shadow:var(--shadow-sm);
  }
  .prod-plan.popular {
    background:linear-gradient(180deg,var(--brand-primary),#123558); color:white;
    border:1px solid rgba(255,255,255,.1); transform:scale(1.03); box-shadow:var(--shadow-xl);
  }
  .prod-plan-pop { position:absolute; top:-12px; left:50%; transform:translateX(-50%); }
  .prod-plan-name { font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--ink-500); margin-bottom:8px; }
  .prod-plan.popular .prod-plan-name { color:rgba(255,255,255,.7); }
  .prod-plan-price { display:flex; align-items:baseline; gap:4px; margin:8px 0; }
  .prod-plan-per { font-size:14px; color:var(--ink-500); }
  .prod-plan.popular .prod-plan-per { color:rgba(255,255,255,.65); }
  .prod-plan-empresas { font-size:13px; color:var(--ink-500); margin-bottom:14px; }
  .prod-plan.popular .prod-plan-empresas { color:rgba(255,255,255,.75); }
  .prod-plan-desc { font-size:14px; margin-bottom:18px; color:var(--ink-700); line-height:1.5; }
  .prod-plan.popular .prod-plan-desc { color:rgba(255,255,255,.9); }
  .prod-plan-features { list-style:none; display:flex; flex-direction:column; gap:10px; margin-bottom:22px; }
  .prod-plan-features li { display:flex; gap:10px; font-size:13.5px; align-items:flex-start; }
  .prod-plan-features svg { color:var(--brand-accent-2); flex-shrink:0; margin-top:2px; }
  .prod-plan.popular .prod-plan-features svg { color:var(--brand-accent); }
</style>
