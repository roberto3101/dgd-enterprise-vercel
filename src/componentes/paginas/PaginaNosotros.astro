---
import Icon from '@componentes/ui/Icon.astro';
import SectionHeader from '@componentes/ui/SectionHeader.astro';
import CTAPanel from '@componentes/ui/CTAPanel.astro';
import type { Idioma } from '@helpers/idiomas';
interface Props { datos: any; idioma: Idioma; }
const { datos, idioma } = Astro.props;
const contactoHref = `/${idioma}/contacto/`;
---
<section class="nosotros-hero">
  <div class="nosotros-hero-img" data-parallax="0.4">
    <img src="/imagenes/oficina-lima.webp" alt="Oficinas Grupo DGD Lima" loading="eager" fetchpriority="high" />
  </div>
  <div class="nosotros-hero-overlay"></div>
  <div class="container" style="position:relative;max-width:920px;text-align:center;z-index:2;">
    <div class="eyebrow" style="color:var(--gold-400);" data-anim="reveal-up">{datos.eyebrow}</div>
    <h1 data-anim="hero-title" style="margin-top:12px;color:white;">{datos.tituloPre}<span class="gradient-text">{datos.tituloGradient}</span>{datos.tituloPost}</h1>
    <p data-anim="reveal-up" style="font-size:19px;color:rgba(255,255,255,.85);margin:22px auto 0;max-width:720px;line-height:1.6;">{datos.descripcion}</p>
  </div>
</section>

<section>
  <div class="container" style="max-width:980px;">
    <div class="historia-grid">
      <div>
        <div class="eyebrow">{datos.historia.eyebrow}</div>
        <h2 style="margin-top:8px;">{datos.historia.titulo}</h2>
        <div style="display:flex;flex-direction:column;gap:20px;margin-top:28px;font-size:15.5px;color:var(--ink-700);line-height:1.7;">
          {datos.historia.parrafos.map((p: string) => <p>{p}</p>)}
        </div>
      </div>
      <div class="historia-cards">
        {datos.historia.cards.map((m: any) => (
          <div class="card" style="padding:20px;border-radius:14px;">
            <div class="mono" style="font-size:12px;color:var(--brand-accent-2);font-weight:600;">{m.y}</div>
            <div style="font-weight:700;margin:6px 0;font-size:15px;">{m.t}</div>
            <div style="font-size:12.5px;color:var(--ink-500);line-height:1.5;">{m.d}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="section-alt">
  <div class="container">
    <SectionHeader eyebrow={datos.mvv.eyebrow} titulo={datos.mvv.titulo} />
    <div class="grid-3">
      {datos.mvv.items.map((m: any) => (
        <div class="card" style="border-radius:18px;padding:28px;background:var(--bg);">
          <div class="mvv-icon"><Icon name={m.icon} size={22} /></div>
          <h3 style="font-size:20px;margin-bottom:10px;">{m.title}</h3>
          <p style="font-size:14.5px;color:var(--ink-500);line-height:1.6;">{m.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section>
  <div class="container">
    <div class="alianza-panel">
      <div class="alianza-glow"></div>
      <div class="alianza-grid">
        <div>
          <span class="badge badge-pop">{datos.alianza.badge}</span>
          <h2 style="color:white;margin-top:14px;">{datos.alianza.titulo}</h2>
          <p style="color:rgba(255,255,255,.82);font-size:17px;margin-top:16px;line-height:1.6;">{datos.alianza.descripcion}</p>
          <ul class="alianza-bullets">
            {datos.alianza.bullets.map((b: string) => (
              <li><Icon name="check" size={18} /><span>{b}</span></li>
            ))}
          </ul>
        </div>
        <div>
          <div class="alianza-card">
            <div class="alianza-logo"><span>code</span></div>
            <div style="font-weight:700;font-size:20px;margin-bottom:6px;">{datos.alianza.cardTitulo}</div>
            <div style="font-size:13px;color:rgba(255,255,255,.7);line-height:1.5;">{datos.alianza.cardDesc}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container">
    <SectionHeader eyebrow={datos.equipo.eyebrow} titulo={datos.equipo.titulo} descripcion={datos.equipo.descripcion} />
    <div class="equipo-foto-wrap" data-anim="img-zoom">
      <img src="/imagenes/equipo-reunion.webp" alt="Equipo Grupo DGD trabajando en Lima" loading="lazy" />
      <div class="equipo-foto-caption">
        <div class="mono" style="font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--gold-400);font-weight:600;">Sesión semanal</div>
        <div style="font-weight:700;color:white;font-size:16px;margin-top:4px;">Equipo de implementación · Lima</div>
      </div>
    </div>
    <div class="equipo-grid" data-anim="stagger">
      {datos.equipo.items.map((p: any) => (
        <div style="text-align:center;padding:20px;">
          <div class="equipo-avatar" style={`background:linear-gradient(135deg, ${p.c}, color-mix(in srgb, ${p.c} 55%, black));`}>{p.init}</div>
          <div style="font-weight:700;font-size:15px;">{p.name}</div>
          <div style="font-size:12.5px;color:var(--ink-500);margin-top:3px;">{p.role}</div>
        </div>
      ))}
    </div>
    <div class="mono" style="text-align:center;margin-top:24px;font-size:13px;color:var(--ink-500);">{datos.equipo.nota}</div>
  </div>
</section>

<section class="section-alt">
  <div class="container" style="max-width:900px;">
    <SectionHeader eyebrow={datos.constitucion.eyebrow} titulo={datos.constitucion.titulo} />
    <div class="card" style="padding:32px;border-radius:18px;">
      <div class="constitucion-grid">
        {datos.constitucion.items.map((r: any) => (
          <div>
            <div class="constitucion-label">{r.l}</div>
            <div style="font-size:15px;color:var(--ink-900);font-weight:500;">{r.v}</div>
          </div>
        ))}
      </div>
      <div class="mono" style="margin-top:20px;font-size:12.5px;color:var(--ink-500);">{datos.constitucion.nota}</div>
    </div>
  </div>
</section>

<CTAPanel titulo={datos.cta.titulo} descripcion={datos.cta.descripcion} ctaPrimario={datos.cta.primario} hrefPrimario={contactoHref} />

<style>
  .historia-grid { display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:center; }
  @media (max-width:900px) { .historia-grid { grid-template-columns:1fr; } }
  .historia-cards { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .mvv-icon {
    width:48px;height:48px;border-radius:12px;
    background:color-mix(in srgb,var(--brand-accent) 12%,transparent);
    color:var(--brand-accent-2);display:grid;place-items:center;margin-bottom:16px;
  }
  .alianza-panel {
    border-radius:24px; background:linear-gradient(135deg,var(--brand-primary),#123558);
    padding:clamp(36px,5vw,56px); color:white; position:relative; overflow:hidden;
  }
  .alianza-glow {
    position:absolute; right:-80px; top:-80px; width:320px; height:320px; border-radius:50%;
    background:radial-gradient(circle,rgba(20,184,166,.3),transparent 70%);
  }
  .alianza-grid { position:relative; display:grid; grid-template-columns:1.5fr 1fr; gap:48px; align-items:center; }
  @media (max-width:900px) { .alianza-grid { grid-template-columns:1fr; } }
  .alianza-bullets { list-style:none; margin-top:20px; display:flex; flex-direction:column; gap:8px; color:rgba(255,255,255,.9); font-size:14.5px; }
  .alianza-bullets li { display:flex; gap:10px; }
  .alianza-bullets svg { color:var(--brand-accent); flex-shrink:0; }
  .alianza-card {
    background:rgba(255,255,255,.08); border-radius:18px; padding:32px;
    border:1px solid rgba(255,255,255,.15); backdrop-filter:blur(12px); text-align:center;
  }
  .alianza-logo {
    width:90px; height:90px; margin:0 auto 18px; border-radius:20px;
    background:rgba(255,255,255,.1); display:grid; place-items:center;
    font-size:32px; font-weight:800; letter-spacing:-0.03em;
  }
  .alianza-logo span { color:var(--brand-accent); }
  .equipo-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:20px; }
  .equipo-avatar {
    width:120px; height:120px; margin:0 auto 14px; border-radius:24px;
    color:white; display:grid; place-items:center;
    font-weight:700; font-size:36px; letter-spacing:-0.03em; box-shadow:var(--shadow);
  }
  .constitucion-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:24px; }
  @media (max-width:600px) { .constitucion-grid { grid-template-columns:1fr; } }
  .constitucion-label {
    font-size:12px; color:var(--ink-500); font-weight:600;
    text-transform:uppercase; letter-spacing:.06em; margin-bottom:4px;
  }

  .nosotros-hero {
    position:relative; min-height:520px;
    display:grid; place-items:center; padding:120px 0 96px; overflow:hidden;
  }
  .nosotros-hero-img { position:absolute; inset:0; z-index:0; }
  .nosotros-hero-img img {
    width:100%; height:100%; object-fit:cover;
  }
  .nosotros-hero-overlay {
    position:absolute; inset:0; z-index:1;
    background:
      radial-gradient(ellipse at center, rgba(4,26,46,.55), rgba(4,26,46,.85) 70%),
      linear-gradient(180deg, rgba(4,26,46,.4) 0%, rgba(4,26,46,.92) 100%);
  }

  .equipo-foto-wrap {
    position:relative; margin:32px 0 56px; border-radius:24px; overflow:hidden;
    box-shadow:var(--shadow-xl); aspect-ratio:16/8;
  }
  .equipo-foto-wrap img {
    width:100%; height:100%; object-fit:cover; display:block;
  }
  .equipo-foto-caption {
    position:absolute; bottom:24px; left:24px; padding:14px 18px;
    background:rgba(4,26,46,.78); backdrop-filter:blur(14px) saturate(160%);
    border:1px solid rgba(212,175,55,.25); border-radius:12px;
  }
  @media (max-width:700px) {
    .equipo-foto-wrap { aspect-ratio:4/3; border-radius:16px; }
    .equipo-foto-caption { left:14px; bottom:14px; padding:10px 14px; }
  }
</style>
