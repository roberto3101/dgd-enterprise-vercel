---
import Icon from '@componentes/ui/Icon.astro';
import type { Idioma } from '@helpers/idiomas';
interface Props { datos: any; idioma: Idioma; }
const { datos } = Astro.props;
---
<section style="padding:72px 0 32px;">
  <div class="container" style="text-align:center;max-width:720px;">
    <div class="eyebrow">{datos.eyebrow}</div>
    <h1 style="margin-top:8px;">{datos.titulo}</h1>
    <p style="font-size:18px;color:var(--ink-500);margin-top:18px;">{datos.descripcion}</p>
  </div>
</section>

<section style="padding:16px 0 72px;">
  <div class="container">
    <div class="contacto-grid">
      <form id="contacto-form" class="card" style="padding:36px;border-radius:20px;">
        <h3 style="font-size:20px;margin-bottom:24px;">{datos.form.titulo}</h3>
        <div class="form-grid">
          <div class="field">
            <label>{datos.form.nombre}</label>
            <input class="input" name="nombre" required />
          </div>
          <div class="field">
            <label>{datos.form.empresa}</label>
            <input class="input" name="empresa" required />
          </div>
          <div class="field">
            <label>{datos.form.ruc}</label>
            <input class="input" name="ruc" inputmode="numeric" maxlength="11" placeholder={datos.form.rucPlaceholder} />
          </div>
          <div class="field">
            <label>{datos.form.telefono}</label>
            <input class="input" name="telefono" placeholder={datos.form.telefonoPlaceholder} />
          </div>
          <div class="field field-full">
            <label>{datos.form.email}</label>
            <input type="email" class="input" name="email" required />
          </div>
          <div class="field">
            <label>{datos.form.producto}</label>
            <select class="select" name="producto">
              {datos.form.productos.map((p: string) => <option>{p}</option>)}
            </select>
          </div>
          <div class="field">
            <label>{datos.form.usuarios}</label>
            <select class="select" name="usuarios">
              {datos.form.rangos.map((p: string) => <option>{p}</option>)}
            </select>
          </div>
          <div class="field field-full">
            <label>{datos.form.mensaje}</label>
            <textarea class="textarea" name="mensaje" placeholder={datos.form.mensajePlaceholder}></textarea>
          </div>
        </div>
        <div class="form-foot">
          <label class="form-policy">
            <input type="checkbox" required />
            <span>{datos.form.politica}</span>
          </label>
          <button type="submit" class="btn btn-primary btn-lg" id="form-submit">
            <span id="form-submit-text">{datos.form.submit}</span>
            <Icon name="send" size={16} />
          </button>
        </div>
        <div id="form-success" class="form-success" hidden>{datos.form.exito}</div>
      </form>

      <aside class="contacto-side">
        <div class="card" style="padding:24px;border-radius:16px;">
          <h4 class="side-title">{datos.sidebar.titulo}</h4>
          <ul class="side-list">
            <li>
              <div class="side-icon"><Icon name="phone" size={16} /></div>
              <div><div class="side-label">{datos.sidebar.telefono.label}</div><div class="side-val">{datos.sidebar.telefono.valor}</div></div>
            </li>
            <li>
              <div class="side-icon"><Icon name="whatsapp" size={16} /></div>
              <div><div class="side-label">{datos.sidebar.whatsapp.label}</div><div class="side-val">{datos.sidebar.whatsapp.valor}</div></div>
            </li>
            <li>
              <div class="side-icon"><Icon name="mail" size={16} /></div>
              <div><div class="side-label">{datos.sidebar.email.label}</div><div class="side-val">{datos.sidebar.email.valor}</div></div>
            </li>
            <li>
              <div class="side-icon"><Icon name="mapPin" size={16} /></div>
              <div><div class="side-label">{datos.sidebar.oficina.label}</div><div class="side-val">{datos.sidebar.oficina.valor}</div></div>
            </li>
          </ul>
        </div>

        <div class="horarios-card">
          <div class="horarios-head">
            <Icon name="clock" size={18} />
            <h4 style="color:white;margin:0;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;">{datos.horarios.titulo}</h4>
          </div>
          {datos.horarios.items.map((h: any, i: number) => (
            <div class={`horario-row ${i === datos.horarios.items.length - 1 ? 'last' : ''}`}>
              <span style="color:rgba(255,255,255,.75);">{h.d}</span>
              <span style="font-weight:600;">{h.h}</span>
            </div>
          ))}
        </div>

        <a href={`https://wa.me/51999999999?text=Hola%20DGD`} target="_blank" rel="noopener" class="btn wa-btn">
          <Icon name="whatsapp" size={20} />{datos.whatsappCta}
        </a>
      </aside>
    </div>
  </div>
</section>

<section style="padding:0 0 72px;">
  <div class="container">
    <div class="mapa-wrap">
      <svg viewBox="0 0 800 360" style="width:100%;height:100%;background:var(--bg-alt);">
        <g stroke="var(--ink-200)" stroke-width="1" fill="none">
          {Array.from({ length: 12 }).map((_, i) => <line x1={i * 70} y1="0" x2={i * 70} y2="360" />)}
          {Array.from({ length: 6 }).map((_, i) => <line x1="0" y1={i * 65} x2="800" y2={i * 65} />)}
        </g>
        <g stroke="var(--ink-300)" stroke-width="3" fill="none">
          <line x1="0" y1="160" x2="800" y2="160" />
          <line x1="350" y1="0" x2="350" y2="360" />
        </g>
        <rect x="500" y="40" width="160" height="80" fill="color-mix(in srgb, #14B8A6 15%, transparent)" rx="6" />
        <rect x="100" y="220" width="120" height="80" fill="color-mix(in srgb, #14B8A6 15%, transparent)" rx="6" />
        <text x="30" y="155" font-size="11" fill="var(--ink-500)" font-family="var(--font-mono)">{datos.mapa.calleH}</text>
        <text x="360" y="30" font-size="11" fill="var(--ink-500)" font-family="var(--font-mono)">{datos.mapa.calleV}</text>
        <g transform="translate(380, 175)">
          <circle r="24" fill="var(--brand-accent)" opacity=".25" />
          <circle r="14" fill="var(--brand-accent)" />
          <path d="M 0 -28 C -10 -28 -14 -20 -14 -14 C -14 -4 0 8 0 8 C 0 8 14 -4 14 -14 C 14 -20 10 -28 0 -28 Z" fill="var(--brand-primary)" />
          <circle cy="-15" r="5" fill="white" />
        </g>
      </svg>
      <div class="mapa-tag">
        <div style="font-weight:700;margin-bottom:4px;">{datos.mapa.titulo}</div>
        <div style="font-size:13px;color:var(--ink-500);">{datos.mapa.direccion}</div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ sending: datos.form.enviando, submit: datos.form.submit }}>
  const form = document.getElementById('contacto-form');
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const rucEl = form.querySelector('[name=ruc]');
    if (rucEl.value && rucEl.value.length !== 11) {
      rucEl.style.borderColor = '#EF4444';
      return;
    }
    const btn = document.getElementById('form-submit');
    document.getElementById('form-submit-text').textContent = sending;
    btn.disabled = true;
    setTimeout(() => {
      form.reset();
      document.getElementById('form-success').hidden = false;
      document.getElementById('form-submit-text').textContent = submit;
      btn.disabled = false;
      setTimeout(() => { document.getElementById('form-success').hidden = true; }, 5000);
    }, 900);
  });
  document.querySelector('[name=ruc]')?.addEventListener('input', (e) => {
    e.target.value = e.target.value.replace(/\D/g, '').slice(0, 11);
    e.target.style.borderColor = '';
  });
</script>

<style>
  .contacto-grid { display:grid; grid-template-columns:1.3fr 1fr; gap:40px; align-items:start; }
  @media (max-width:900px) { .contacto-grid { grid-template-columns:1fr; } }
  .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  @media (max-width:600px) { .form-grid { grid-template-columns:1fr; } }
  .field-full { grid-column:1/-1; }
  .form-foot {
    margin-top:24px; display:flex; gap:14px; align-items:center;
    justify-content:space-between; flex-wrap:wrap;
  }
  .form-policy { font-size:13px; color:var(--ink-500); display:flex; gap:10px; align-items:flex-start; max-width:380px; }
  .form-policy input { margin-top:3px; }
  .form-success {
    margin-top:16px; padding:12px 16px; border-radius:10px;
    background:color-mix(in srgb,var(--brand-accent) 15%, transparent);
    color:var(--brand-accent-2); font-weight:600;
  }
  .contacto-side { display:flex; flex-direction:column; gap:18px; }
  .side-title {
    font-size:14px; font-weight:700; text-transform:uppercase;
    letter-spacing:.08em; color:var(--ink-500); margin-bottom:16px;
  }
  .side-list { list-style:none; display:flex; flex-direction:column; gap:14px; }
  .side-list li { display:flex; gap:12px; align-items:flex-start; }
  .side-icon {
    width:36px; height:36px; border-radius:10px;
    background:color-mix(in srgb,var(--brand-accent) 12%, transparent);
    color:var(--brand-accent-2); display:grid; place-items:center; flex-shrink:0;
  }
  .side-label { font-size:12px; color:var(--ink-500); font-weight:600; }
  .side-val { font-weight:600; font-family:var(--font-mono); font-size:13px; line-height:1.4; }
  .horarios-card {
    padding:24px; border-radius:16px;
    background:linear-gradient(135deg,var(--brand-primary),#123558); color:white;
  }
  .horarios-head { display:flex; align-items:center; gap:10px; margin-bottom:14px; color:var(--brand-accent); }
  .horario-row {
    display:flex; justify-content:space-between; padding:8px 0;
    border-bottom:1px solid rgba(255,255,255,.1); font-size:14px;
  }
  .horario-row.last { border-bottom:none; }
  .wa-btn {
    background:#25D366; color:white; justify-content:center;
    padding:14px 22px; border-radius:14px; font-weight:700;
  }
  .mapa-wrap {
    border-radius:20px; overflow:hidden; border:1px solid var(--ink-200);
    box-shadow:var(--shadow); height:360px; position:relative; background:var(--bg-alt);
  }
  .mapa-tag {
    position:absolute; bottom:20px; left:20px; padding:14px;
    background:var(--bg); border-radius:12px; box-shadow:var(--shadow); max-width:280px;
  }
</style>
