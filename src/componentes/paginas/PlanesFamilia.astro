---
import Icon from '@componentes/ui/Icon.astro';
import type { Idioma } from '@helpers/idiomas';

interface Props {
  familia: any;
  textos: any;
  contactoHref: string;
  idioma: Idioma;
}
const { familia, textos, contactoHref } = Astro.props;
const fSlug = familia.slug;
const ctaTexto = textos.ctaAdquirir || textos.ctaCotizar;
const ctaDetalles = textos.ctaDetalles || (Astro.props.idioma === 'en' ? 'See details' : 'Ver detalles');

const paletaTonos = ['azul', 'oscuro', 'rojo', 'verde', 'morado', 'naranja'];
---
<section class="familia" data-familia={fSlug}>
  <div class="container">
    <header class="fam-head">
      <div class="eyebrow"><Icon name={familia.icon} size={14} />{familia.subtitulo}</div>
      <h2 class="fam-title">{familia.name}</h2>
    </header>

    {familia.variantes.map((v: any) => (
      <div class="variante-bloque">
        <h3 class="variante-titulo">{v.name}</h3>
        {v.implementacion && (
          <div class="var-impl">
            <Icon name="zap" size={16} /><span>{v.implementacion}</span>
          </div>
        )}
        {v.limite && <p class="var-limite">{v.limite}</p>}

        <div class={`planes-row planes-row-${Math.min(v.planes.length, 4)}`}>
          {v.planes.map((p: any, idx: number) => {
            const tono = paletaTonos[idx % paletaTonos.length];
            const todosItems = (v.grupos || []).flatMap((g: any) => g.items.map((it: any) => ({ ...it, grupo: g.title })));
            return (
              <article
                class={`plan-card tono-${tono} ${p.popular ? 'popular' : ''}`}
                data-card-toggle
                tabindex="0"
                role="button"
                aria-expanded="false"
                aria-label={`${p.name} — click para ver detalles`}
              >
                <div class="plan-flag" aria-hidden="true"></div>
                <div class="plan-inner">
                  {p.popular && <span class="plan-pop">{textos.popularBadge}</span>}

                  <div class="plan-head">
                    <h4 class="plan-name">{p.name}</h4>
                    <div class="plan-price">
                      {p.priceLabel ? (
                        <span class="plan-price-free">{p.priceLabel}</span>
                      ) : (
                        <>
                          <span class="plan-price-cur">S/</span>
                          <span class="plan-price-num">{p.price}</span>
                          <span class="plan-price-per">/mes</span>
                        </>
                      )}
                    </div>
                    {p.limit && <p class="plan-limit">{p.limit}</p>}
                  </div>

                  <div class="plan-resumen">
                    <p class="plan-resumen-text">
                      {todosItems.filter((it: any) => it.values[p.key] === true || (typeof it.values[p.key] === 'string' && it.values[p.key])).length}
                      {' '}características incluidas
                    </p>
                  </div>

                  <div class="plan-detalles" hidden>
                    <ul class="plan-feat-list">
                      {todosItems.map((it: any) => {
                        const val = it.values[p.key];
                        const incluido = val === true || (typeof val === 'string' && val !== '—' && val !== '');
                        const textoVal = typeof val === 'string' && val !== '' ? val : null;
                        return (
                          <li class={incluido ? 'incl' : 'no-incl'}>
                            {incluido
                              ? <Icon name="check" size={16} stroke={2.5} />
                              : <Icon name="x" size={16} stroke={2.5} />}
                            <span class="feat-text">
                              <span class="feat-name">{it.name}</span>
                              {textoVal && <span class="feat-value">{textoVal}</span>}
                            </span>
                          </li>
                        );
                      })}
                    </ul>
                  </div>

                  <div class="plan-actions">
                    <button type="button" class="btn-detalles" data-toggle-trigger>
                      <span class="btn-detalles-label" data-label-cerrado>{ctaDetalles}</span>
                      <span class="btn-detalles-label" data-label-abierto hidden>−</span>
                    </button>
                    <a class="btn-adquirir" href={contactoHref} onclick="event.stopPropagation();">
                      {ctaTexto}
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>

        {v.tablaVolumen && (
          <div class="tabla-extra">
            <h4 class="tabla-extra-title">{v.tablaVolumen.titulo}</h4>
            <div class="tabla-scroll">
              <table class="tabla-vol">
                <thead>
                  <tr>{v.tablaVolumen.headers.map((h: string) => <th>{h}</th>)}</tr>
                </thead>
                <tbody>
                  {v.tablaVolumen.rows.map((r: string[]) => (
                    <tr>{r.map((c: string, idx: number) => <td class={idx === 1 ? 'td-price' : ''}>{c}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {v.extras && (
          <div class="tabla-extra">
            <h4 class="tabla-extra-title">{v.extras.titulo}</h4>
            {v.extras.subtitulo && <p class="tabla-extra-sub">{v.extras.subtitulo}</p>}
            <div class="tabla-scroll">
              <table class="tabla-vol">
                <thead>
                  <tr>{v.extras.headers.map((h: string) => <th>{h}</th>)}</tr>
                </thead>
                <tbody>
                  {v.extras.rows.map((r: string[]) => (
                    <tr>{r.map((c: string) => <td>{c}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
            {v.extras.extra && (
              <div class="extra-box">
                <h5>{v.extras.extra.titulo}</h5>
                <ul>{v.extras.extra.items.map((s: string) => <li><Icon name="check" size={14} stroke={2.5} />{s}</li>)}</ul>
              </div>
            )}
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  /* ============ FAMILIA + VARIANTES ============ */
  .familia { padding: 64px 0; border-top: 1px solid var(--ink-200); }
  .familia:first-of-type { border-top: 0; padding-top: 32px; }
  /* Permitimos que esta seccion respire mas ancho que el container global */
  .familia > .container { max-width: min(1480px, 96vw); }
  .fam-head { max-width: 760px; margin: 0 auto 48px; text-align: center; }
  .fam-title {
    font-size: clamp(32px, 4.4vw, 46px);
    margin: 10px 0 14px;
    letter-spacing: -0.02em;
    color: var(--ink-900);
  }

  .variante-bloque {
    margin-bottom: 64px;
    padding-top: 32px;
    border-top: 1px dashed var(--ink-200);
  }
  .variante-bloque:first-child { border-top: 0; padding-top: 0; }
  .variante-titulo {
    font-size: clamp(22px, 2.8vw, 28px);
    text-align: center;
    margin-bottom: 18px;
    letter-spacing: -0.01em;
    color: var(--ink-900);
  }

  .var-impl {
    max-width: 760px; margin: 0 auto 14px;
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap; justify-content: center;
    padding: 12px 18px; border-radius: 12px;
    background: color-mix(in srgb, var(--brand-accent) 12%, transparent);
    color: var(--ink-900); font-size: 15px; font-weight: 600;
  }
  .var-impl svg { color: var(--brand-accent-2); flex-shrink: 0; }
  .var-limite {
    text-align: center; font-size: 14px; color: var(--ink-500);
    margin: 0 auto 32px; max-width: 720px; line-height: 1.5;
  }

  /* ============ GRID DE CARDS ============ */
  /* align-items: start permite que cada card se expanda solo cuando se hace
     click sin estirar a las hermanas. */
  .planes-row {
    display: grid;
    gap: 28px;
    margin: 0;
    width: 100%;
    align-items: start;
  }
  .planes-row-1 {
    grid-template-columns: minmax(280px, 480px);
    justify-content: center;
  }
  .planes-row-2 {
    grid-template-columns: repeat(2, minmax(280px, 1fr));
    max-width: 880px;
    margin: 0 auto;
  }
  .planes-row-3 {
    grid-template-columns: repeat(3, minmax(280px, 1fr));
  }
  .planes-row-4 {
    grid-template-columns: repeat(4, minmax(260px, 1fr));
    gap: 22px;
  }
  @media (max-width: 1280px) {
    .planes-row-4 { grid-template-columns: repeat(3, minmax(260px, 1fr)); }
  }
  @media (max-width: 1100px) {
    .planes-row-3, .planes-row-4 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .planes-row, .planes-row-2, .planes-row-3, .planes-row-4 {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }

  /* ============ CARD CLICKEABLE ============ */
  .plan-card {
    --tono-color: #2188ff;
    position: relative;
    isolation: isolate;
    margin: 18px 0;
    cursor: pointer;
    outline: none;
    transition: transform .25s ease;
  }
  .plan-card:hover { transform: translateY(-3px); }
  .plan-card:focus-visible .plan-inner {
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--tono-color) 40%, transparent),
                0 12px 28px rgba(0,0,0,.12);
  }
  .plan-card.tono-azul    { --tono-color: #2188ff; }
  .plan-card.tono-oscuro  { --tono-color: #0b2740; }
  .plan-card.tono-rojo    { --tono-color: #e63946; }
  .plan-card.tono-verde   { --tono-color: #16a34a; }
  .plan-card.tono-morado  { --tono-color: #7c3aed; }
  .plan-card.tono-naranja { --tono-color: #ea580c; }

  /* En modo oscuro suavizamos el tono "oscuro" para que no desaparezca */
  :root.dark .plan-card.tono-oscuro { --tono-color: #4b6f9c; }

  .plan-flag {
    position: absolute;
    top: 16px; bottom: 16px;
    left: -12px; right: -12px;
    background: var(--tono-color);
    z-index: -1;
    clip-path: polygon(
      0% 12px, 14px 0%, calc(100% - 14px) 0%, 100% 12px,
      100% calc(100% - 12px), calc(100% - 14px) 100%, 14px 100%, 0% calc(100% - 12px)
    );
    opacity: .92;
    transition: opacity .25s, top .25s, bottom .25s;
  }
  .plan-card:hover .plan-flag { top: 12px; bottom: 12px; opacity: 1; }

  .plan-inner {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--ink-200);
    border-radius: 10px;
    padding: 36px 28px 26px;
    box-shadow: 0 10px 28px rgba(15, 23, 42, .08);
    display: flex; flex-direction: column;
    /* sin height: 100% para que cada card crezca solo cuando expande
       y no arrastre a las hermanas */
    min-height: 100%;
    transition: box-shadow .25s;
  }
  :root.dark .plan-inner {
    background: var(--bg-alt);
    box-shadow: 0 10px 28px rgba(0,0,0,.35);
  }

  .plan-pop {
    position: absolute;
    top: -14px; left: 50%; transform: translateX(-50%);
    background: var(--brand-accent);
    color: var(--ink-900);
    padding: 6px 14px; border-radius: 999px;
    font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase;
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
  }

  /* ===== Cabecera ===== */
  .plan-head { text-align: center; padding-bottom: 24px; border-bottom: 1px solid var(--ink-100); }
  .plan-name {
    font-size: clamp(34px, 4.2vw, 44px);
    font-weight: 300;
    color: var(--tono-color);
    margin: 0 0 16px;
    letter-spacing: -0.01em;
    line-height: 1.05;
  }
  :root.dark .plan-name { font-weight: 400; }

  .plan-price {
    display: flex; align-items: baseline; justify-content: center; gap: 4px;
    flex-wrap: wrap;
  }
  .plan-price-cur { font-size: 18px; font-weight: 600; color: var(--ink-700); }
  .plan-price-num {
    font-size: clamp(38px, 4.6vw, 48px);
    font-weight: 800;
    color: var(--ink-900);
    letter-spacing: -0.03em; line-height: 1;
  }
  .plan-price-per { font-size: 14px; color: var(--ink-500); margin-left: 2px; }
  .plan-price-free {
    font-size: clamp(28px, 3.6vw, 36px);
    font-weight: 800;
    color: var(--tono-color);
  }
  .plan-limit {
    font-size: 13px;
    color: var(--ink-500);
    margin: 10px 0 0;
    line-height: 1.45;
  }

  /* ===== Resumen ===== */
  .plan-resumen { padding: 20px 0; text-align: center; }
  .plan-resumen-text {
    font-size: 14px;
    color: var(--ink-700);
    font-weight: 600;
    margin: 0;
  }

  /* ===== Detalles (toggle) ===== */
  .plan-detalles {
    margin: 0 0 20px;
    padding: 18px 0 4px;
    border-top: 1px solid var(--ink-100);
    animation: planDetallesAbrir .28s ease;
  }
  @keyframes planDetallesAbrir {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .plan-feat-list {
    list-style: none;
    padding: 0; margin: 0;
    display: flex; flex-direction: column;
    gap: 10px;
  }
  .plan-feat-list li {
    display: flex; align-items: flex-start;
    gap: 10px;
    font-size: 14.5px;
    line-height: 1.45;
  }
  .plan-feat-list li.incl { color: var(--ink-900); }
  .plan-feat-list li.no-incl {
    color: var(--ink-500);
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, var(--ink-500) 50%, transparent);
    text-decoration-thickness: 1px;
  }
  .plan-feat-list svg { flex-shrink: 0; margin-top: 3px; }
  .plan-feat-list li.incl svg { color: #16a34a; }
  .plan-feat-list li.no-incl svg { color: #dc2626; }
  .feat-text { display: flex; flex-direction: column; gap: 2px; }
  .feat-name { font-weight: 500; }
  .feat-value {
    font-size: 12px;
    font-weight: 600;
    color: var(--brand-primary);
    background: color-mix(in srgb, var(--brand-accent) 18%, transparent);
    padding: 2px 8px; border-radius: 999px;
    align-self: flex-start;
  }

  /* ===== Acciones ===== */
  .plan-actions {
    display: flex;
    gap: 10px;
    margin-top: auto;
    padding-top: 18px;
  }
  .btn-detalles {
    flex: 1;
    padding: 12px 14px;
    background: transparent;
    color: var(--tono-color);
    border: 2px solid var(--tono-color);
    border-radius: 4px;
    font-size: 13.5px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background .18s, color .18s;
    font-family: inherit;
  }
  .btn-detalles:hover {
    background: color-mix(in srgb, var(--tono-color) 12%, transparent);
  }
  .btn-adquirir {
    flex: 1;
    padding: 12px 14px;
    background: var(--tono-color);
    color: #fff;
    text-align: center;
    border-radius: 4px;
    font-size: 13.5px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: filter .18s, transform .18s, box-shadow .18s;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--tono-color) 32%, transparent);
    display: inline-flex; align-items: center; justify-content: center;
  }
  .btn-adquirir:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--tono-color) 45%, transparent);
  }

  /* ===== Tablas extras (volumen / extras) ===== */
  .tabla-extra { margin-top: 36px; }
  .tabla-extra-title { font-size: 20px; margin-bottom: 10px; color: var(--ink-900); }
  .tabla-extra-sub { color: var(--ink-500); font-size: 15px; margin-bottom: 14px; }
  .tabla-scroll { overflow-x: auto; }
  .tabla-vol {
    width: 100%; min-width: 500px; border-collapse: collapse;
    border: 1px solid var(--ink-200); border-radius: 12px; overflow: hidden;
    font-size: 15px;
    background: var(--bg);
  }
  .tabla-vol thead th {
    background: var(--brand-primary); color: white;
    padding: 14px 16px; text-align: left; font-weight: 700; font-size: 14px;
  }
  .tabla-vol tbody td {
    padding: 12px 16px; border-bottom: 1px solid var(--ink-200);
    color: var(--ink-700);
  }
  .tabla-vol tbody tr:nth-child(even) td { background: var(--ink-100); }
  .tabla-vol .td-price { font-weight: 700; color: var(--brand-accent-2); }

  .extra-box {
    margin-top: 20px;
    padding: 20px 24px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--brand-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--brand-accent) 30%, transparent);
  }
  .extra-box h5 { margin: 0 0 12px; font-size: 16px; color: var(--ink-900); }
  .extra-box ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .extra-box li { display: flex; align-items: flex-start; gap: 8px; font-size: 14.5px; color: var(--ink-700); }
  .extra-box svg { color: var(--brand-accent-2); flex-shrink: 0; margin-top: 3px; }
</style>

<script is:inline>
  (function () {
    function alternarDetalle(card) {
      const detalles = card.querySelector('.plan-detalles');
      const labelCerrado = card.querySelector('[data-label-cerrado]');
      const labelAbierto = card.querySelector('[data-label-abierto]');
      if (!detalles) return;
      const expandido = card.getAttribute('aria-expanded') === 'true';
      const nuevo = !expandido;
      card.setAttribute('aria-expanded', String(nuevo));
      detalles.hidden = !nuevo;
      if (labelCerrado && labelAbierto) {
        labelCerrado.hidden = nuevo;
        labelAbierto.hidden = !nuevo;
        labelAbierto.textContent = nuevo ? '− Ocultar detalles' : '−';
      }
    }

    function montar() {
      document.querySelectorAll('[data-card-toggle]').forEach((card) => {
        if (card.__planToggleArmed) return;
        card.__planToggleArmed = true;

        // Click sobre la card
        card.addEventListener('click', (evento) => {
          // No alternar si el click vino del botón Adquirir (es un <a>)
          if (evento.target.closest('.btn-adquirir')) return;
          alternarDetalle(card);
        });

        // Teclado: Enter o Espacio
        card.addEventListener('keydown', (evento) => {
          if (evento.key === 'Enter' || evento.key === ' ') {
            evento.preventDefault();
            alternarDetalle(card);
          }
        });

        // El botón "Ver detalles" no necesita lógica propia: el click burbujea
        // hasta la card. Solo evitamos navegación accidental.
        const trigger = card.querySelector('[data-toggle-trigger]');
        if (trigger) {
          trigger.addEventListener('click', (evento) => {
            evento.stopPropagation();
            alternarDetalle(card);
          });
        }
      });
    }

    montar();
    document.addEventListener('astro:page-load', montar);
  })();
</script>
