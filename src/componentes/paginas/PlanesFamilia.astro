---
import Icon from '@componentes/ui/Icon.astro';
import type { Idioma } from '@helpers/idiomas';

interface Props {
  familia: any;
  textos: any;
  contactoHref: string;
  idioma: Idioma;
  variantesFiltro?: string[];
  ocultarEncabezado?: boolean;
}
const { familia, textos, contactoHref, idioma, variantesFiltro, ocultarEncabezado } = Astro.props;
const fSlug = familia.slug;
const ctaTexto = textos.ctaAdquirir || textos.ctaCotizar;
const ctaDetalles = textos.ctaDetalles || (idioma === 'en' ? 'See details' : 'Ver detalles');

const paletaTonos = ['azul', 'oscuro', 'rojo', 'verde', 'morado', 'naranja', 'cian', 'rosa'];

// Filtrado opcional de variantes (para que un selector externo pueda mostrar
// solo el subconjunto que le interesa, ej. solo "Restaurantes" o solo "Grifo").
const variantesAMostrar = variantesFiltro && variantesFiltro.length > 0
  ? familia.variantes.filter((v: any) => variantesFiltro.includes(v.slug))
  : familia.variantes;

// Aplanamos: todas las cards en una sola lista para mostrarlas en una grid.
const todasLasCards = variantesAMostrar.flatMap((variante: any) =>
  variante.planes.map((plan: any) => ({ plan, variante }))
);
const variantesConTablas = variantesAMostrar.filter((v: any) => v.tablaVolumen || v.extras);
---
<section class="familia" data-familia={fSlug}>
  <div class="container">
    {!ocultarEncabezado && (
      <header class="fam-head">
        <div class="eyebrow"><Icon name={familia.icon} size={14} />{familia.subtitulo}</div>
        <h2 class="fam-title">{familia.name}</h2>
      </header>
    )}

    <div class={`planes-row planes-row-${Math.min(todasLasCards.length, 4)}`}>
      {todasLasCards.map(({ plan, variante }, idx) => {
        const tono = paletaTonos[idx % paletaTonos.length];
        const todosItems = (variante.grupos || []).flatMap((g: any) =>
          g.items.map((it: any) => ({ ...it, grupo: g.title })),
        );
        const tieneVariosPlanes = variante.planes.length > 1;
        const nombreCard = tieneVariosPlanes
          ? `${variante.name} — ${plan.name}`
          : variante.name;
        return (
          <article
            class={`plan-card tono-${tono} ${plan.popular ? 'popular' : ''}`}
            data-card-toggle
            tabindex="0"
            role="button"
            aria-expanded="false"
            aria-label={`${nombreCard} — click para ver detalles`}
          >
            <div class="plan-flag" aria-hidden="true"></div>
            <div class="plan-inner">
              {plan.popular && <span class="plan-pop">{textos.popularBadge}</span>}

              <div class="plan-head">
                <div class="plan-eyebrow">{variante.subtitulo || familia.subtitulo}</div>
                <h4 class="plan-name">{nombreCard}</h4>
                <div class="plan-price">
                  {plan.priceLabel ? (
                    <span class="plan-price-free">{plan.priceLabel}</span>
                  ) : (
                    <>
                      <span class="plan-price-cur">S/</span>
                      <span class="plan-price-num">{plan.price}</span>
                      <span class="plan-price-per">/mes</span>
                    </>
                  )}
                </div>
                <p class="plan-limit">
                  {plan.limit || variante.limite || ''}
                </p>
              </div>

              <div class="plan-resumen">
                <p class="plan-resumen-text">
                  {todosItems.filter((it: any) => {
                    const v = it.values[plan.key];
                    return v === true || (typeof v === 'string' && v !== '' && v !== '—');
                  }).length}
                  {' '}{idioma === 'en' ? 'features included' : 'características incluidas'}
                </p>
              </div>

              <div class="plan-detalles" hidden>
                {variante.implementacion && (
                  <div class="plan-impl-detalle">
                    <span class="plan-impl-icono"><Icon name="zap" size={14} stroke={2.5} /></span>
                    <span>{variante.implementacion}</span>
                  </div>
                )}
                <ul class="plan-feat-list">
                  {todosItems.map((it: any) => {
                    const val = it.values[plan.key];
                    const incluido = val === true || (typeof val === 'string' && val !== '—' && val !== '');
                    const textoVal = typeof val === 'string' && val !== '' && val !== '—' ? val : null;
                    return (
                      <li class={incluido ? 'incl' : 'no-incl'}>
                        <span class={`feat-icono ${incluido ? 'feat-incl' : 'feat-noincl'}`} aria-hidden="true">
                          {incluido
                            ? <Icon name="check" size={14} stroke={3} />
                            : <Icon name="x" size={14} stroke={3} />}
                        </span>
                        <span class="feat-text">
                          <span class="feat-name">{it.name}</span>
                          {textoVal && <span class="feat-value">{textoVal}</span>}
                        </span>
                      </li>
                    );
                  })}
                </ul>
              </div>

              <div class="plan-actions">
                <button type="button" class="btn-detalles" data-toggle-trigger>
                  <span data-label-cerrado>{ctaDetalles}</span>
                  <span data-label-abierto hidden>{idioma === 'en' ? 'Hide details' : 'Ocultar detalles'}</span>
                </button>
                <a class="btn-adquirir" href={contactoHref} onclick="event.stopPropagation();">
                  {ctaTexto}
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    {variantesConTablas.length > 0 && (
      <div class="extras-bloque">
        {variantesConTablas.map((v: any) => (
          <div class="extras-card">
            <div class="extras-encabezado">
              <span class="extras-variante">{v.name}</span>
            </div>
            {v.tablaVolumen && (
              <div class="tabla-extra">
                <h4 class="tabla-extra-title">{v.tablaVolumen.titulo}</h4>
                <div class="tabla-scroll">
                  <table class="tabla-vol">
                    <thead>
                      <tr>{v.tablaVolumen.headers.map((h: string) => <th>{h}</th>)}</tr>
                    </thead>
                    <tbody>
                      {v.tablaVolumen.rows.map((r: string[]) => (
                        <tr>{r.map((c: string, idx: number) => <td class={idx === 1 ? 'td-price' : ''}>{c}</td>)}</tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}
            {v.extras && (
              <div class="tabla-extra">
                <h4 class="tabla-extra-title">{v.extras.titulo}</h4>
                {v.extras.subtitulo && <p class="tabla-extra-sub">{v.extras.subtitulo}</p>}
                <div class="tabla-scroll">
                  <table class="tabla-vol">
                    <thead>
                      <tr>{v.extras.headers.map((h: string) => <th>{h}</th>)}</tr>
                    </thead>
                    <tbody>
                      {v.extras.rows.map((r: string[]) => (
                        <tr>{r.map((c: string) => <td>{c}</td>)}</tr>
                      ))}
                    </tbody>
                  </table>
                </div>
                {v.extras.extra && (
                  <div class="extra-box">
                    <h5>{v.extras.extra.titulo}</h5>
                    <ul>{v.extras.extra.items.map((s: string) => <li><Icon name="check" size={14} stroke={2.5} />{s}</li>)}</ul>
                  </div>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  /* ============ FAMILIA ============ */
  .familia { padding: 64px 0; border-top: 1px solid var(--ink-200); }
  .familia:first-of-type { border-top: 0; padding-top: 32px; }
  .familia > .container { max-width: min(1480px, 96vw); }

  .fam-head { max-width: 760px; margin: 0 auto 56px; text-align: center; }
  .fam-title {
    font-size: clamp(32px, 4.4vw, 46px);
    margin: 10px 0 14px;
    letter-spacing: -0.02em;
    color: var(--ink-900);
  }

  /* ============ GRID UNIFICADA DE CARDS ============ */
  .planes-row {
    display: grid;
    gap: 28px;
    margin: 0;
    width: 100%;
    align-items: start;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  /* Sobrescritos para conteos pequeños y centrarlos */
  .planes-row-1 { grid-template-columns: minmax(280px, 480px); justify-content: center; }
  .planes-row-2 { grid-template-columns: repeat(2, minmax(280px, 1fr)); max-width: 880px; margin: 0 auto; }
  .planes-row-3 { grid-template-columns: repeat(3, minmax(280px, 1fr)); }
  .planes-row-4 { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }

  @media (max-width: 720px) {
    .planes-row, .planes-row-1, .planes-row-2, .planes-row-3, .planes-row-4 {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }

  /* ============ CARD CLICKEABLE ============ */
  .plan-card {
    --tono-color: #2188ff;
    position: relative;
    isolation: isolate;
    margin: 18px 0;
    cursor: pointer;
    outline: none;
    transition: transform .25s ease;
  }
  .plan-card:hover { transform: translateY(-3px); }
  .plan-card:focus-visible .plan-inner {
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--tono-color) 40%, transparent),
                0 12px 28px rgba(0,0,0,.12);
  }
  .plan-card.tono-azul    { --tono-color: #2188ff; }
  .plan-card.tono-oscuro  { --tono-color: #0b2740; }
  .plan-card.tono-rojo    { --tono-color: #e63946; }
  .plan-card.tono-verde   { --tono-color: #16a34a; }
  .plan-card.tono-morado  { --tono-color: #7c3aed; }
  .plan-card.tono-naranja { --tono-color: #ea580c; }
  .plan-card.tono-cian    { --tono-color: #0891b2; }
  .plan-card.tono-rosa    { --tono-color: #db2777; }

  :root.dark .plan-card.tono-oscuro { --tono-color: #4b6f9c; }

  .plan-flag {
    position: absolute;
    top: 16px; bottom: 16px;
    left: -12px; right: -12px;
    background: var(--tono-color);
    z-index: -1;
    clip-path: polygon(
      0% 12px, 14px 0%, calc(100% - 14px) 0%, 100% 12px,
      100% calc(100% - 12px), calc(100% - 14px) 100%, 14px 100%, 0% calc(100% - 12px)
    );
    opacity: .92;
    transition: opacity .25s, top .25s, bottom .25s;
  }
  .plan-card:hover .plan-flag { top: 12px; bottom: 12px; opacity: 1; }

  .plan-inner {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--ink-200);
    border-radius: 10px;
    padding: 32px 26px 24px;
    box-shadow: 0 10px 28px rgba(15, 23, 42, .08);
    display: flex; flex-direction: column;
    min-height: 100%;
    transition: box-shadow .25s;
  }
  :root.dark .plan-inner {
    background: var(--bg-alt);
    box-shadow: 0 10px 28px rgba(0,0,0,.35);
  }

  .plan-pop {
    position: absolute;
    top: -14px; left: 50%; transform: translateX(-50%);
    background: var(--brand-accent);
    color: var(--ink-900);
    padding: 6px 14px; border-radius: 999px;
    font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase;
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
  }

  .plan-head { text-align: center; padding-bottom: 20px; border-bottom: 1px solid var(--ink-100); }
  .plan-eyebrow {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .1em;
    color: color-mix(in srgb, var(--tono-color) 80%, var(--ink-500));
    margin-bottom: 8px;
  }
  .plan-name {
    font-size: clamp(22px, 2.2vw, 28px);
    font-weight: 400;
    color: var(--tono-color);
    margin: 0 0 14px;
    letter-spacing: -0.01em;
    line-height: 1.18;
    /* Suficiente para 2 lineas — todas las cards alinean su precio */
    min-height: calc(28px * 1.18 * 2);
    display: flex; align-items: center; justify-content: center;
    text-align: center;
  }
  :root.dark .plan-name { font-weight: 500; }

  .plan-price {
    display: flex; align-items: baseline; justify-content: center; gap: 4px;
    flex-wrap: wrap;
  }
  .plan-price-cur { font-size: 16px; font-weight: 600; color: var(--ink-700); }
  .plan-price-num {
    font-size: clamp(34px, 3.6vw, 42px);
    font-weight: 800;
    color: var(--ink-900);
    letter-spacing: -0.03em; line-height: 1;
  }
  .plan-price-per { font-size: 13px; color: var(--ink-500); margin-left: 2px; }
  .plan-price-free {
    font-size: clamp(24px, 2.6vw, 30px);
    font-weight: 800;
    color: var(--tono-color);
  }
  .plan-limit {
    font-size: 12.5px;
    color: var(--ink-500);
    margin: 10px 0 0;
    line-height: 1.45;
    /* Reservamos espacio uniforme para que todas las cards alineen
       su zona de precio aunque el limite sea distinto */
    min-height: 36px;
    display: flex; align-items: center; justify-content: center;
  }

  .plan-resumen { padding: 18px 0; text-align: center; }
  .plan-resumen-text {
    font-size: 14px;
    color: var(--ink-700);
    font-weight: 600;
    margin: 0;
  }

  .plan-detalles {
    margin: 0 0 18px;
    padding: 16px 0 4px;
    border-top: 1px solid var(--ink-100);
    animation: planDetallesAbrir .28s ease;
  }
  @keyframes planDetallesAbrir {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  /* Caja "implementación" dentro de los detalles (texto largo) */
  .plan-impl-detalle {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 12px 14px;
    margin-bottom: 16px;
    border-radius: 10px;
    background: color-mix(in srgb, var(--tono-color) 10%, transparent);
    border-left: 3px solid var(--tono-color);
    font-size: 13px; line-height: 1.5;
    color: var(--ink-700);
  }
  .plan-impl-detalle .plan-impl-icono {
    flex-shrink: 0;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--tono-color);
    color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
  }

  .plan-feat-list {
    list-style: none;
    padding: 0; margin: 0;
    display: flex; flex-direction: column;
    gap: 12px;
  }
  .plan-feat-list li {
    display: flex; align-items: flex-start;
    gap: 12px;
    font-size: 14px;
    line-height: 1.45;
  }
  .plan-feat-list li.incl { color: var(--ink-900); }
  .plan-feat-list li.no-incl {
    color: var(--ink-500);
  }
  .plan-feat-list li.no-incl .feat-name {
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, #dc2626 60%, transparent);
    text-decoration-thickness: 1px;
  }

  /* Iconos circulares con tamaño y color uniformes */
  .feat-icono {
    flex-shrink: 0;
    width: 22px; height: 22px;
    border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    margin-top: 1px;
  }
  .feat-icono svg { width: 14px; height: 14px; display: block; }
  .feat-incl {
    background: color-mix(in srgb, #16a34a 16%, transparent);
    color: #16a34a;
  }
  .feat-noincl {
    background: color-mix(in srgb, #dc2626 16%, transparent);
    color: #dc2626;
  }
  :root.dark .feat-incl {
    background: color-mix(in srgb, #16a34a 22%, transparent);
    color: #4ade80;
  }
  :root.dark .feat-noincl {
    background: color-mix(in srgb, #dc2626 22%, transparent);
    color: #f87171;
  }

  .feat-text { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .feat-name { font-weight: 500; }
  .feat-value {
    font-size: 11.5px;
    font-weight: 600;
    color: var(--ink-900);
    background: color-mix(in srgb, var(--brand-accent) 22%, transparent);
    padding: 2px 8px; border-radius: 999px;
    align-self: flex-start;
  }

  .plan-actions {
    display: flex;
    gap: 10px;
    margin-top: auto;
    padding-top: 16px;
  }
  .btn-detalles {
    flex: 1;
    padding: 11px 12px;
    background: transparent;
    color: var(--tono-color);
    border: 2px solid var(--tono-color);
    border-radius: 4px;
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background .18s, color .18s;
    font-family: inherit;
  }
  .btn-detalles:hover {
    background: color-mix(in srgb, var(--tono-color) 12%, transparent);
  }
  .btn-adquirir {
    flex: 1;
    padding: 11px 12px;
    background: var(--tono-color);
    color: #fff;
    text-align: center;
    border-radius: 4px;
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: filter .18s, transform .18s, box-shadow .18s;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--tono-color) 32%, transparent);
    display: inline-flex; align-items: center; justify-content: center;
  }
  .btn-adquirir:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--tono-color) 45%, transparent);
  }

  /* ============ Bloque de tablas extras ============ */
  .extras-bloque { margin-top: 56px; display: flex; flex-direction: column; gap: 32px; }
  .extras-card {
    padding: 28px;
    border: 1px solid var(--ink-200);
    border-radius: 16px;
    background: var(--bg);
  }
  :root.dark .extras-card { background: var(--bg-alt); }
  .extras-encabezado {
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--ink-100);
  }
  .extras-variante {
    font-size: 17px; font-weight: 700;
    color: var(--ink-900);
    letter-spacing: -0.01em;
  }

  .tabla-extra { margin-top: 12px; }
  .tabla-extra:first-child { margin-top: 0; }
  .tabla-extra-title { font-size: 18px; margin-bottom: 10px; color: var(--ink-900); }
  .tabla-extra-sub { color: var(--ink-500); font-size: 14px; margin-bottom: 12px; }
  .tabla-scroll { overflow-x: auto; }
  .tabla-vol {
    width: 100%; min-width: 500px; border-collapse: collapse;
    border: 1px solid var(--ink-200); border-radius: 12px; overflow: hidden;
    font-size: 14.5px;
    background: var(--bg);
  }
  :root.dark .tabla-vol { background: var(--bg-alt); }
  .tabla-vol thead th {
    background: var(--brand-primary); color: white;
    padding: 14px 16px; text-align: left; font-weight: 700; font-size: 14px;
  }
  .tabla-vol tbody td {
    padding: 12px 16px; border-bottom: 1px solid var(--ink-200);
    color: var(--ink-700);
  }
  .tabla-vol tbody tr:nth-child(even) td { background: var(--ink-100); }
  .tabla-vol .td-price { font-weight: 700; color: var(--brand-accent-2); }

  .extra-box {
    margin-top: 18px;
    padding: 18px 22px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--brand-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--brand-accent) 30%, transparent);
  }
  .extra-box h5 { margin: 0 0 12px; font-size: 16px; color: var(--ink-900); }
  .extra-box ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .extra-box li { display: flex; align-items: flex-start; gap: 8px; font-size: 14.5px; color: var(--ink-700); }
  .extra-box svg { color: var(--brand-accent-2); flex-shrink: 0; margin-top: 3px; }
</style>

<script is:inline>
  (function () {
    function alternarDetalle(card) {
      const detalles = card.querySelector('.plan-detalles');
      const labelCerrado = card.querySelector('[data-label-cerrado]');
      const labelAbierto = card.querySelector('[data-label-abierto]');
      if (!detalles) return;
      const expandido = card.getAttribute('aria-expanded') === 'true';
      const nuevo = !expandido;
      card.setAttribute('aria-expanded', String(nuevo));
      detalles.hidden = !nuevo;
      if (labelCerrado && labelAbierto) {
        labelCerrado.hidden = nuevo;
        labelAbierto.hidden = !nuevo;
      }
    }

    function montar() {
      document.querySelectorAll('[data-card-toggle]').forEach((card) => {
        if (card.__planToggleArmed) return;
        card.__planToggleArmed = true;

        card.addEventListener('click', (evento) => {
          if (evento.target.closest('.btn-adquirir')) return;
          alternarDetalle(card);
        });

        card.addEventListener('keydown', (evento) => {
          if (evento.key === 'Enter' || evento.key === ' ') {
            evento.preventDefault();
            alternarDetalle(card);
          }
        });

        const trigger = card.querySelector('[data-toggle-trigger]');
        if (trigger) {
          trigger.addEventListener('click', (evento) => {
            evento.stopPropagation();
            alternarDetalle(card);
          });
        }
      });
    }

    montar();
    document.addEventListener('astro:page-load', montar);
  })();
</script>
