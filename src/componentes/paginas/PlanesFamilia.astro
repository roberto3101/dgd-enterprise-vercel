---
import Icon from '@componentes/ui/Icon.astro';
import type { Idioma } from '@helpers/idiomas';

interface Props {
  familia: any;
  textos: any;
  contactoHref: string;
  idioma: Idioma;
}
const { familia, textos, contactoHref } = Astro.props;
const fSlug = familia.slug;
const ctaTexto = textos.ctaAdquirir || textos.ctaCotizar;

// Paleta cíclica para diferenciar planes (basic, standard, premium, ...)
const paletaTonos = ['azul', 'oscuro', 'rojo', 'verde', 'morado', 'naranja'];
---
<section class="familia" data-familia={fSlug}>
  <div class="container">
    <header class="fam-head">
      <div class="eyebrow"><Icon name={familia.icon} size={14} />{familia.subtitulo}</div>
      <h2 class="fam-title">{familia.name}</h2>
    </header>

    {familia.variantes.map((v: any) => (
      <div class="variante-bloque" data-panel={`${fSlug}-${v.slug}`}>
        <h3 class="variante-titulo">{v.name}</h3>

        {v.implementacion && (
          <div class="var-impl">
            <Icon name="zap" size={16} /><span>{v.implementacion}</span>
          </div>
        )}
        {v.limite && <div class="var-limite">{v.limite}</div>}

        <div class={`planes-row planes-row-${Math.min(v.planes.length, 4)}`}>
          {v.planes.map((p: any, idx: number) => {
            const tono = paletaTonos[idx % paletaTonos.length];
            const todosItems = (v.grupos || []).flatMap((g: any) => g.items.map((it: any) => ({ ...it, grupo: g.title })));
            const visibles = todosItems.slice(0, 6);
            return (
              <article class={`plan-card tono-${tono} ${p.popular ? 'popular' : ''}`}>
                <div class="plan-card-flag" aria-hidden="true"></div>
                <div class="plan-card-inner">
                  {p.popular && <span class="plan-pop-tag">{textos.popularBadge}</span>}
                  <h4 class="plan-card-name">{p.name}</h4>
                  <ul class="plan-feat-list">
                    {visibles.map((it: any) => {
                      const val = it.values[p.key];
                      const incluido = val === true || (typeof val === 'string' && val !== '—' && val !== '');
                      return (
                        <li class={incluido ? 'incl' : 'no-incl'}>
                          {incluido
                            ? <Icon name="check" size={18} stroke={2.5} />
                            : <Icon name="x" size={18} stroke={2.5} />}
                          <span>{it.name}</span>
                        </li>
                      );
                    })}
                  </ul>
                  <div class="plan-card-price">
                    {p.priceLabel ? (
                      <span class="plan-price-free">{p.priceLabel}</span>
                    ) : (
                      <>
                        <span class="plan-price-cur">S/</span>
                        <span class="plan-price-num">{p.price}</span>
                        <span class="plan-price-per">/mes</span>
                      </>
                    )}
                  </div>
                  {p.limit && <p class="plan-card-limit">{p.limit}</p>}
                  <a class="plan-card-btn" href={contactoHref}>{ctaTexto}</a>
                </div>
              </article>
            );
          })}
        </div>

        <div class="modulos-incluidos">
          <div class="modulos-label">{textos.modulosIncluidos}</div>
          <div class="modulos-chips">
            {(v.grupos || []).map((g: any) => (
              <span class="modulo-chip"><Icon name="check" size={12} stroke={2.5} />{g.title}</span>
            ))}
          </div>
        </div>

        <div class="tabla-completa">
          <h4 class="tabla-completa-titulo">{textos.tablaCompararTitulo || textos.verTabla}</h4>
          <div class="tabla-scroll">
            <table class="tabla-comp">
              <thead>
                <tr>
                  <th class="th-feat">{textos.incluyeActualizaciones}</th>
                  {v.planes.map((p: any) => (
                    <th class={`th-plan ${p.popular ? 'popular' : ''}`}>
                      <div class="th-pname">{p.name}</div>
                      <div class="th-pprice">
                        {p.priceLabel ? p.priceLabel : `S/ ${p.price}`}
                      </div>
                      {p.limit && <div class="th-plimit">{p.limit}</div>}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {(v.grupos || []).map((g: any) => (
                  <>
                    <tr class="tr-group">
                      <td colspan={v.planes.length + 1}>{g.title}</td>
                    </tr>
                    {g.items.map((it: any) => (
                      <tr>
                        <td class="td-feat">{it.name}</td>
                        {v.planes.map((p: any) => {
                          const val = it.values[p.key];
                          return (
                            <td class={`td-val ${p.popular ? 'popular' : ''}`}>
                              {typeof val === 'string' ? (
                                <span class="td-text">{val}</span>
                              ) : val === true ? (
                                <span class="td-yes" aria-label={textos.leyendaIncluido}><Icon name="check" size={16} stroke={2.5} /></span>
                              ) : (
                                <span class="td-no" aria-label={textos.leyendaNoIncluido}><Icon name="x" size={14} stroke={2} /></span>
                              )}
                            </td>
                          );
                        })}
                      </tr>
                    ))}
                  </>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {v.tablaVolumen && (
          <div class="tabla-extra">
            <h4 class="tabla-extra-title">{v.tablaVolumen.titulo}</h4>
            <div class="tabla-scroll">
              <table class="tabla-vol">
                <thead>
                  <tr>{v.tablaVolumen.headers.map((h: string) => <th>{h}</th>)}</tr>
                </thead>
                <tbody>
                  {v.tablaVolumen.rows.map((r: string[]) => (
                    <tr>{r.map((c: string, idx: number) => <td class={idx === 1 ? 'td-price' : ''}>{c}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {v.extras && (
          <div class="tabla-extra">
            <h4 class="tabla-extra-title">{v.extras.titulo}</h4>
            {v.extras.subtitulo && <p class="tabla-extra-sub">{v.extras.subtitulo}</p>}
            <div class="tabla-scroll">
              <table class="tabla-vol">
                <thead>
                  <tr>{v.extras.headers.map((h: string) => <th>{h}</th>)}</tr>
                </thead>
                <tbody>
                  {v.extras.rows.map((r: string[]) => (
                    <tr>{r.map((c: string) => <td>{c}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
            {v.extras.extra && (
              <div class="extra-box">
                <h5>{v.extras.extra.titulo}</h5>
                <ul>{v.extras.extra.items.map((s: string) => <li><Icon name="check" size={14} stroke={2.5} />{s}</li>)}</ul>
              </div>
            )}
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .familia { padding: 64px 0; border-top: 1px solid var(--ink-200); }
  .familia:first-of-type { border-top: 0; padding-top: 32px; }
  .fam-head { max-width: 760px; margin: 0 auto 48px; text-align: center; }
  .fam-title { font-size: clamp(32px, 4.4vw, 46px); margin: 10px 0 14px; letter-spacing: -0.02em; }

  .variante-bloque {
    margin-bottom: 64px;
    padding-top: 32px;
    border-top: 1px dashed var(--ink-200);
  }
  .variante-bloque:first-child { border-top: 0; padding-top: 0; }
  .variante-titulo {
    font-size: clamp(22px, 2.8vw, 28px);
    text-align: center;
    margin-bottom: 18px;
    letter-spacing: -0.01em;
  }

  .var-impl {
    max-width: 760px; margin: 0 auto 14px;
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap; justify-content: center;
    padding: 12px 18px; border-radius: 12px;
    background: color-mix(in srgb, var(--brand-accent) 12%, transparent);
    color: var(--ink-900); font-size: 15px; font-weight: 600;
  }
  .var-impl svg { color: var(--brand-accent-2); flex-shrink: 0; }
  .var-limite {
    text-align: center; font-size: 14px; color: var(--ink-500);
    margin: 0 auto 32px; max-width: 720px; line-height: 1.5;
  }

  /* ===== Cards estilo "Basic / Standard / Premium" ===== */
  .planes-row {
    display: grid;
    gap: 28px;
    margin: 0 auto 48px;
    max-width: 1200px;
  }
  .planes-row-1 { grid-template-columns: minmax(280px, 420px); justify-content: center; }
  .planes-row-2 { grid-template-columns: repeat(2, minmax(260px, 1fr)); max-width: 800px; }
  .planes-row-3 { grid-template-columns: repeat(3, minmax(260px, 1fr)); }
  .planes-row-4 { grid-template-columns: repeat(4, minmax(240px, 1fr)); gap: 20px; }
  @media (max-width: 1100px) {
    .planes-row-3, .planes-row-4 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .planes-row, .planes-row-2, .planes-row-3, .planes-row-4 {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }

  .plan-card {
    --tono-color: #2188ff;
    position: relative;
    isolation: isolate;
    padding: 0;
    margin: 18px 0;
  }
  .plan-card.tono-azul    { --tono-color: #2188ff; }
  .plan-card.tono-oscuro  { --tono-color: #0b2740; }
  .plan-card.tono-rojo    { --tono-color: #e63946; }
  .plan-card.tono-verde   { --tono-color: #16a34a; }
  .plan-card.tono-morado  { --tono-color: #7c3aed; }
  .plan-card.tono-naranja { --tono-color: #ea580c; }

  /* Decoración lateral tipo "flag" detrás de la card */
  .plan-card-flag {
    position: absolute;
    top: 18px; bottom: 18px;
    left: -14px; right: -14px;
    background: var(--tono-color);
    z-index: -1;
    clip-path: polygon(
      0% 12px, 14px 0%, calc(100% - 14px) 0%, 100% 12px,
      100% calc(100% - 12px), calc(100% - 14px) 100%, 14px 100%, 0% calc(100% - 12px)
    );
    opacity: .92;
  }

  .plan-card-inner {
    position: relative;
    background: #ffffff;
    border: 1px solid var(--ink-200);
    border-radius: 8px;
    padding: 38px 30px 32px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, .08);
    display: flex; flex-direction: column;
    min-height: 100%;
  }

  .plan-pop-tag {
    position: absolute;
    top: -14px; left: 50%; transform: translateX(-50%);
    background: var(--brand-accent);
    color: var(--ink-900);
    padding: 6px 14px; border-radius: 999px;
    font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase;
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
  }

  .plan-card-name {
    text-align: center;
    font-size: clamp(34px, 4.2vw, 44px);
    font-weight: 300;
    color: var(--tono-color);
    margin: 4px 0 24px;
    letter-spacing: -0.01em;
    line-height: 1.05;
  }

  .plan-feat-list {
    list-style: none;
    padding: 0;
    margin: 0 0 26px;
    display: flex; flex-direction: column;
    gap: 14px;
    border-top: 1px solid var(--ink-100);
    padding-top: 22px;
  }
  .plan-feat-list li {
    display: flex; align-items: flex-start;
    gap: 12px;
    font-size: 16px;
    line-height: 1.45;
    color: var(--ink-900);
  }
  .plan-feat-list li.no-incl {
    color: var(--ink-500);
    text-decoration: line-through;
    text-decoration-color: rgba(220, 38, 38, .35);
    text-decoration-thickness: 1px;
  }
  .plan-feat-list svg { flex-shrink: 0; margin-top: 2px; }
  .plan-feat-list li.incl svg { color: #16a34a; }
  .plan-feat-list li.no-incl svg { color: #dc2626; }

  .plan-card-price {
    text-align: center;
    margin: 8px 0 4px;
    display: flex; align-items: baseline; justify-content: center; gap: 4px;
    flex-wrap: wrap;
  }
  .plan-price-cur { font-size: 20px; font-weight: 600; color: var(--ink-700); }
  .plan-price-num {
    font-size: clamp(40px, 5vw, 52px);
    font-weight: 800;
    color: var(--ink-900);
    letter-spacing: -0.03em; line-height: 1;
  }
  .plan-price-per { font-size: 15px; color: var(--ink-500); margin-left: 2px; }
  .plan-price-free {
    font-size: clamp(28px, 3.6vw, 36px);
    font-weight: 800;
    color: var(--tono-color);
  }

  .plan-card-limit {
    text-align: center;
    font-size: 13px;
    color: var(--ink-500);
    margin: 4px 0 22px;
    line-height: 1.45;
    min-height: 18px;
  }

  .plan-card-btn {
    display: block;
    width: 100%;
    margin-top: auto;
    padding: 14px 24px;
    background: var(--tono-color);
    color: #fff;
    text-align: center;
    border: 0;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: filter .18s, transform .18s, box-shadow .18s;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--tono-color) 35%, transparent);
  }
  .plan-card-btn:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
    box-shadow: 0 8px 22px color-mix(in srgb, var(--tono-color) 45%, transparent);
  }

  /* ===== Módulos incluidos ===== */
  .modulos-incluidos {
    margin: 0 auto 28px;
    max-width: 920px;
    padding: 18px 22px;
    background: var(--ink-100);
    border: 1px solid var(--ink-200);
    border-radius: 14px;
  }
  .modulos-label {
    font-size: 12px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--ink-500); margin-bottom: 12px;
  }
  .modulos-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .modulo-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 12px; border-radius: 999px;
    background: var(--bg);
    border: 1px solid var(--ink-200);
    font-size: 13.5px; font-weight: 600;
    color: var(--ink-900);
  }
  .modulo-chip svg { color: var(--brand-accent-2); flex-shrink: 0; }

  /* ===== Tabla comparativa SIEMPRE visible ===== */
  .tabla-completa {
    margin-top: 28px;
    border: 1px solid var(--ink-200);
    border-radius: 16px;
    background: var(--bg);
    overflow: hidden;
  }
  .tabla-completa-titulo {
    margin: 0;
    padding: 18px 22px;
    font-size: 17px;
    font-weight: 700;
    color: var(--ink-900);
    background: var(--ink-100);
    border-bottom: 1px solid var(--ink-200);
    letter-spacing: -0.01em;
  }

  .tabla-scroll { overflow-x: auto; }
  .tabla-comp {
    width: 100%; min-width: 640px;
    border-collapse: collapse;
    font-size: 15px;
  }
  .tabla-comp thead th {
    padding: 16px 14px;
    text-align: left;
    background: var(--bg);
    font-weight: 700;
    color: var(--ink-900);
    border-bottom: 2px solid var(--ink-200);
    vertical-align: top;
    font-size: 14.5px;
  }
  .tabla-comp .th-feat { width: 38%; min-width: 240px; }
  .tabla-comp .th-plan { text-align: center; min-width: 130px; }
  .tabla-comp .th-plan.popular { background: color-mix(in srgb, var(--brand-primary) 10%, var(--bg)); }
  .tabla-comp .th-pname { font-size: 15px; font-weight: 700; }
  .tabla-comp .th-pprice { font-size: 16px; font-weight: 800; color: var(--brand-accent-2); margin-top: 4px; }
  .tabla-comp .th-plimit { font-size: 12px; color: var(--ink-500); margin-top: 6px; font-weight: 500; line-height: 1.35; }

  .tabla-comp tbody .tr-group td {
    background: var(--ink-100);
    padding: 12px 16px;
    font-weight: 700; font-size: 13px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--brand-primary);
    border-top: 1px solid var(--ink-200);
  }
  .tabla-comp tbody .td-feat {
    padding: 12px 16px;
    color: var(--ink-700);
    border-bottom: 1px solid var(--ink-200);
    vertical-align: top;
    line-height: 1.45;
    font-size: 14.5px;
  }
  .tabla-comp tbody .td-val {
    padding: 12px 14px;
    text-align: center;
    border-bottom: 1px solid var(--ink-200);
    border-left: 1px solid var(--ink-200);
  }
  .tabla-comp tbody .td-val.popular {
    background: color-mix(in srgb, var(--brand-primary) 5%, transparent);
  }
  .tabla-comp .td-yes {
    color: #16a34a;
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; border-radius: 50%;
    background: color-mix(in srgb, #16a34a 14%, transparent);
  }
  .tabla-comp .td-no {
    color: #dc2626;
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; border-radius: 50%;
    background: color-mix(in srgb, #dc2626 10%, transparent);
  }
  .tabla-comp .td-text {
    font-size: 13px; font-weight: 600;
    padding: 4px 10px; border-radius: 999px;
    background: color-mix(in srgb, var(--brand-accent) 20%, transparent);
    color: var(--ink-900);
  }

  /* ===== Tablas extras (volumen, etc) ===== */
  .tabla-extra { margin-top: 36px; }
  .tabla-extra-title { font-size: 20px; margin-bottom: 10px; }
  .tabla-extra-sub { color: var(--ink-500); font-size: 15px; margin-bottom: 14px; }
  .tabla-vol {
    width: 100%; min-width: 500px; border-collapse: collapse;
    border: 1px solid var(--ink-200); border-radius: 12px; overflow: hidden;
    font-size: 15px;
  }
  .tabla-vol thead th {
    background: var(--brand-primary); color: white;
    padding: 14px 16px; text-align: left; font-weight: 700; font-size: 14px;
  }
  .tabla-vol tbody td {
    padding: 12px 16px; border-bottom: 1px solid var(--ink-200);
    color: var(--ink-700);
  }
  .tabla-vol tbody tr:nth-child(even) td { background: var(--ink-100); }
  .tabla-vol .td-price { font-weight: 700; color: var(--brand-accent-2); }

  .extra-box {
    margin-top: 20px;
    padding: 20px 24px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--brand-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--brand-accent) 30%, transparent);
  }
  .extra-box h5 { margin: 0 0 12px; font-size: 16px; }
  .extra-box ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .extra-box li { display: flex; align-items: flex-start; gap: 8px; font-size: 14.5px; color: var(--ink-700); }
  .extra-box svg { color: var(--brand-accent-2); flex-shrink: 0; margin-top: 3px; }
</style>
