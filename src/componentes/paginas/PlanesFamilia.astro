---
import Icon from '@componentes/ui/Icon.astro';
import type { Idioma } from '@helpers/idiomas';

interface Props {
  familia: any;
  textos: any;
  contactoHref: string;
  idioma: Idioma;
}
const { familia, textos, contactoHref } = Astro.props;
const fSlug = familia.slug;
---
<section class="familia" data-familia={fSlug}>
  <div class="container">
    <header class="fam-head">
      <div class="eyebrow"><Icon name={familia.icon} size={14} />{familia.subtitulo}</div>
      <h2 class="fam-title">{familia.name}</h2>
    </header>

    <div class="var-tabs" role="tablist">
      {familia.variantes.map((v: any, i: number) => (
        <button
          type="button"
          class={`var-tab ${i === 0 ? 'active' : ''}`}
          data-var={`${fSlug}-${v.slug}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          <span class="var-tab-name">{v.name}</span>
        </button>
      ))}
    </div>

    {familia.variantes.map((v: any, i: number) => (
      <div class={`var-panel ${i === 0 ? 'active' : ''}`} data-panel={`${fSlug}-${v.slug}`}>
        {v.implementacion && (
          <div class="var-impl">
            <Icon name="zap" size={16} /><span>{v.implementacion}</span>
          </div>
        )}
        {v.limite && <div class="var-limite mono">// {v.limite}</div>}

        <div class="planes-row" data-cols={v.planes.length}>
          {v.planes.map((p: any) => (
            <div class={`plan-card ${p.popular ? 'popular' : ''}`}>
              {p.popular && <span class="badge plan-pop">{textos.popularBadge}</span>}
              <div class="plan-name">{p.name}</div>
              <div class="plan-price">
                {p.priceLabel ? (
                  <span class="plan-num plan-free">{p.priceLabel}</span>
                ) : (
                  <>
                    <span class="plan-cur">S/</span>
                    <span class="plan-num">{p.price}</span>
                    <span class="plan-per">/mes</span>
                  </>
                )}
              </div>
              {p.limit && <div class="plan-limit">{p.limit}</div>}
              <a class={`btn ${p.popular ? 'btn-primary' : 'btn-outline'}`} href={contactoHref}>{textos.ctaCotizar}</a>
            </div>
          ))}
        </div>

        <details class="tabla-wrap">
          <summary><Icon name="chevron" size={14} /><span>{textos.verTabla}</span></summary>
          <div class="tabla-scroll">
            <table class="tabla-comp">
              <thead>
                <tr>
                  <th class="th-feat">{textos.incluyeActualizaciones}</th>
                  {v.planes.map((p: any) => (
                    <th class={`th-plan ${p.popular ? 'popular' : ''}`}>
                      <div class="th-pname">{p.name}</div>
                      <div class="th-pprice">
                        {p.priceLabel ? p.priceLabel : `S/ ${p.price}`}
                      </div>
                      {p.limit && <div class="th-plimit">{p.limit}</div>}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {v.grupos.map((g: any) => (
                  <>
                    <tr class="tr-group">
                      <td colspan={v.planes.length + 1}>{g.title}</td>
                    </tr>
                    {g.items.map((it: any) => (
                      <tr>
                        <td class="td-feat">{it.name}</td>
                        {v.planes.map((p: any) => {
                          const val = it.values[p.key];
                          return (
                            <td class={`td-val ${p.popular ? 'popular' : ''}`}>
                              {typeof val === 'string' ? (
                                <span class="td-text">{val}</span>
                              ) : val === true ? (
                                <span class="td-yes" aria-label={textos.leyendaIncluido}><Icon name="check" size={16} stroke={2.5} /></span>
                              ) : (
                                <span class="td-no" aria-label={textos.leyendaNoIncluido}><Icon name="x" size={14} stroke={2} /></span>
                              )}
                            </td>
                          );
                        })}
                      </tr>
                    ))}
                  </>
                ))}
              </tbody>
            </table>
          </div>
        </details>

        {v.tablaVolumen && (
          <div class="tabla-extra">
            <h4 class="tabla-extra-title">{v.tablaVolumen.titulo}</h4>
            <div class="tabla-scroll">
              <table class="tabla-vol">
                <thead>
                  <tr>{v.tablaVolumen.headers.map((h: string) => <th>{h}</th>)}</tr>
                </thead>
                <tbody>
                  {v.tablaVolumen.rows.map((r: string[]) => (
                    <tr>{r.map((c: string, idx: number) => <td class={idx === 1 ? 'td-price' : ''}>{c}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {v.extras && (
          <div class="tabla-extra">
            <h4 class="tabla-extra-title">{v.extras.titulo}</h4>
            {v.extras.subtitulo && <p class="tabla-extra-sub">{v.extras.subtitulo}</p>}
            <div class="tabla-scroll">
              <table class="tabla-vol">
                <thead>
                  <tr>{v.extras.headers.map((h: string) => <th>{h}</th>)}</tr>
                </thead>
                <tbody>
                  {v.extras.rows.map((r: string[]) => (
                    <tr>{r.map((c: string) => <td>{c}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            </div>
            {v.extras.extra && (
              <div class="extra-box">
                <h5>{v.extras.extra.titulo}</h5>
                <ul>{v.extras.extra.items.map((s: string) => <li><Icon name="check" size={14} stroke={2.5} />{s}</li>)}</ul>
              </div>
            )}
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .familia { padding: 56px 0; border-top: 1px solid var(--ink-200); }
  .familia:first-of-type { border-top: 0; padding-top: 24px; }
  .fam-head { max-width: 760px; margin: 0 auto 28px; text-align: center; }
  .fam-title { font-size: clamp(28px, 4vw, 40px); margin: 8px 0 14px; }
  .fam-intro { font-size: 16px; color: var(--ink-500); line-height: 1.6; }

  .var-tabs {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 8px;
    margin-bottom: 28px;
    padding: 6px;
    background: var(--ink-100);
    border-radius: 14px;
    max-width: max-content;
    margin-left: auto; margin-right: auto;
  }
  .var-tab {
    border: 0; background: transparent; cursor: pointer;
    padding: 10px 18px; border-radius: 10px;
    font-weight: 700; color: var(--ink-700); font-size: 14px;
    transition: all .15s;
  }
  .var-tab:hover { background: rgba(0,0,0,.04); }
  .var-tab.active {
    background: var(--bg);
    box-shadow: var(--shadow-sm);
    color: var(--ink-900);
  }

  .var-panel { display: none; }
  .var-panel.active { display: block; }

  .var-impl {
    max-width: 720px; margin: 0 auto 14px;
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    padding: 12px 16px; border-radius: 12px;
    background: color-mix(in srgb, var(--brand-accent) 12%, transparent);
    color: var(--ink-900); font-size: 14px;
  }
  .var-impl svg { color: var(--brand-accent-2); flex-shrink: 0; }
  .var-limite { text-align: center; font-size: 12px; color: var(--ink-500); margin-bottom: 22px; }

  .planes-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
    margin-bottom: 28px;
  }
  .planes-row[data-cols="1"] { grid-template-columns: minmax(260px, 420px); justify-content: center; }
  .planes-row[data-cols="2"] { grid-template-columns: repeat(2, minmax(220px, 1fr)); max-width: 720px; margin-left: auto; margin-right: auto; }
  .planes-row[data-cols="3"] { grid-template-columns: repeat(3, minmax(200px, 1fr)); }

  .plan-card {
    padding: 22px; border-radius: 16px;
    background: var(--bg); border: 1px solid var(--ink-200);
    position: relative; box-shadow: var(--shadow-sm);
    display: flex; flex-direction: column;
  }
  .plan-card.popular {
    background: linear-gradient(180deg, var(--brand-primary), #123558);
    color: white; border-color: rgba(255,255,255,.15);
    box-shadow: var(--shadow-xl); transform: translateY(-4px);
  }
  .plan-pop {
    position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
    background: var(--brand-accent); color: var(--ink-900);
    padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 700;
    letter-spacing: .04em;
  }
  .plan-name { font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--brand-accent-2); margin-bottom: 8px; }
  .plan-card.popular .plan-name { color: var(--brand-accent); }
  .plan-price { display: flex; align-items: baseline; gap: 4px; margin-bottom: 6px; flex-wrap: wrap; }
  .plan-cur { font-size: 18px; font-weight: 600; opacity: .7; }
  .plan-num { font-size: 38px; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
  .plan-num.plan-free { font-size: 26px; color: var(--brand-accent-2); }
  .plan-card.popular .plan-num.plan-free { color: var(--brand-accent); }
  .plan-per { font-size: 13px; color: var(--ink-500); }
  .plan-card.popular .plan-per { color: rgba(255,255,255,.7); }
  .plan-limit { font-size: 12px; color: var(--ink-500); margin-bottom: 16px; min-height: 32px; }
  .plan-card.popular .plan-limit { color: rgba(255,255,255,.75); }
  .plan-card .btn { width: 100%; justify-content: center; margin-top: auto; }

  .tabla-wrap {
    margin-top: 8px;
    border: 1px solid var(--ink-200);
    border-radius: 14px;
    background: var(--bg);
    overflow: hidden;
  }
  .tabla-wrap summary {
    list-style: none;
    padding: 14px 18px;
    cursor: pointer;
    display: flex; align-items: center; gap: 10px;
    font-weight: 600; color: var(--ink-700); font-size: 14px;
    user-select: none;
  }
  .tabla-wrap summary::-webkit-details-marker { display: none; }
  .tabla-wrap summary svg { transition: transform .2s; }
  .tabla-wrap[open] summary svg { transform: rotate(180deg); }
  .tabla-wrap[open] summary { border-bottom: 1px solid var(--ink-200); }

  .tabla-scroll { overflow-x: auto; }
  .tabla-comp {
    width: 100%; min-width: 600px;
    border-collapse: collapse;
    font-size: 13.5px;
  }
  .tabla-comp thead th {
    padding: 14px 12px;
    text-align: left;
    background: var(--ink-100);
    font-weight: 700;
    color: var(--ink-900);
    border-bottom: 1px solid var(--ink-200);
    vertical-align: top;
  }
  .tabla-comp .th-feat { width: 36%; min-width: 220px; }
  .tabla-comp .th-plan { text-align: center; min-width: 110px; }
  .tabla-comp .th-plan.popular { background: color-mix(in srgb, var(--brand-primary) 12%, var(--ink-100)); }
  .tabla-comp .th-pname { font-size: 13px; font-weight: 700; }
  .tabla-comp .th-pprice { font-size: 14px; font-weight: 800; color: var(--brand-accent-2); margin-top: 2px; }
  .tabla-comp .th-plimit { font-size: 11px; color: var(--ink-500); margin-top: 4px; font-weight: 500; line-height: 1.3; }

  .tabla-comp tbody .tr-group td {
    background: var(--ink-100);
    padding: 10px 14px;
    font-weight: 700; font-size: 12px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--brand-primary);
    border-top: 1px solid var(--ink-200);
  }
  .tabla-comp tbody .td-feat {
    padding: 10px 14px;
    color: var(--ink-700);
    border-bottom: 1px solid var(--ink-200);
    vertical-align: top;
    line-height: 1.4;
  }
  .tabla-comp tbody .td-val {
    padding: 10px 12px;
    text-align: center;
    border-bottom: 1px solid var(--ink-200);
    border-left: 1px solid var(--ink-200);
  }
  .tabla-comp tbody .td-val.popular {
    background: color-mix(in srgb, var(--brand-primary) 5%, transparent);
  }
  .tabla-comp .td-yes { color: var(--brand-accent-2); display: inline-flex; }
  .tabla-comp .td-no { color: var(--ink-300); display: inline-flex; }
  .tabla-comp .td-text {
    font-size: 12px; font-weight: 600;
    padding: 3px 8px; border-radius: 999px;
    background: color-mix(in srgb, var(--brand-accent) 18%, transparent);
    color: var(--ink-900);
  }

  .tabla-extra { margin-top: 28px; }
  .tabla-extra-title { font-size: 18px; margin-bottom: 8px; }
  .tabla-extra-sub { color: var(--ink-500); font-size: 14px; margin-bottom: 12px; }
  .tabla-vol {
    width: 100%; min-width: 500px; border-collapse: collapse;
    border: 1px solid var(--ink-200); border-radius: 12px; overflow: hidden;
    font-size: 14px;
  }
  .tabla-vol thead th {
    background: var(--brand-primary); color: white;
    padding: 12px 14px; text-align: left; font-weight: 700; font-size: 13px;
  }
  .tabla-vol tbody td {
    padding: 10px 14px; border-bottom: 1px solid var(--ink-200);
    color: var(--ink-700);
  }
  .tabla-vol tbody tr:nth-child(even) td { background: var(--ink-100); }
  .tabla-vol .td-price { font-weight: 700; color: var(--brand-accent-2); }

  .extra-box {
    margin-top: 18px;
    padding: 18px 20px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--brand-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--brand-accent) 30%, transparent);
  }
  .extra-box h5 { margin: 0 0 10px; font-size: 15px; }
  .extra-box ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .extra-box li { display: flex; align-items: flex-start; gap: 8px; font-size: 13.5px; color: var(--ink-700); }
  .extra-box svg { color: var(--brand-accent-2); flex-shrink: 0; margin-top: 3px; }

  @media (max-width: 640px) {
    .var-tabs { padding: 4px; }
    .var-tab { padding: 8px 12px; }
    .planes-row { grid-template-columns: 1fr !important; }
    .plan-card.popular { transform: none; }
  }
</style>

<script is:inline>
  (function () {
    function setup() {
      document.querySelectorAll('.familia').forEach(fam => {
        const tabs = fam.querySelectorAll('.var-tab');
        const panels = fam.querySelectorAll('.var-panel');
        tabs.forEach(t => {
          if (t.__wired) return;
          t.__wired = true;
          t.addEventListener('click', () => {
            const target = t.getAttribute('data-var');
            tabs.forEach(b => {
              const on = b.getAttribute('data-var') === target;
              b.classList.toggle('active', on);
              b.setAttribute('aria-selected', on ? 'true' : 'false');
            });
            panels.forEach(p => p.classList.toggle('active', p.getAttribute('data-panel') === target));
          });
        });
      });
    }
    setup();
    document.addEventListener('astro:page-load', setup);
  })();
</script>
