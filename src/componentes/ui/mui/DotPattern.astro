---
interface Props {
  width?: number;
  height?: number;
  cx?: number;
  cy?: number;
  cr?: number;
  color?: string;
  mask?: boolean;
  className?: string;
}
const {
  width = 18,
  height = 18,
  cx = 1,
  cy = 1,
  cr = 1,
  color = 'color-mix(in srgb, var(--ink-400) 45%, transparent)',
  mask = true,
  className = '',
} = Astro.props;
const patternId = 'dotpat-' + Math.random().toString(36).slice(2, 9);
---
<svg aria-hidden="true" class={`dot-pattern ${mask ? 'dot-pattern--mask' : ''} ${className}`} style={`color:${color}`}>
  <defs>
    <pattern id={patternId} x="0" y="0" width={width} height={height} patternUnits="userSpaceOnUse">
      <circle cx={cx} cy={cy} r={cr} fill="currentColor" />
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill={`url(#${patternId})`} />
</svg>

<style>
  .dot-pattern {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
  }
  .dot-pattern--mask {
    -webkit-mask-image: radial-gradient(ellipse at center, #000 40%, transparent 80%);
            mask-image: radial-gradient(ellipse at center, #000 40%, transparent 80%);
  }
</style>
