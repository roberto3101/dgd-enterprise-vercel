---
import Icon from './Icon.astro';
interface Props {
  titulo: string;
  descripcion?: string;
  ctaPrimario: string;
  hrefPrimario: string;
  ctaSecundario?: string;
  hrefSecundario?: string;
}
const { titulo, descripcion, ctaPrimario, hrefPrimario, ctaSecundario, hrefSecundario } = Astro.props;
---
<section style="padding:72px 0;">
  <div class="container">
    <div class="cta-panel">
      <div class="cta-panel-glow"></div>
      <div class="cta-panel-ring"></div>
      <div class="cta-panel-inner">
        <div style="max-width:560px;">
          <h2 style="color:white;">{titulo}</h2>
          {descripcion && <p style="color:rgba(255,255,255,.82);margin-top:14px;font-size:17px;">{descripcion}</p>}
        </div>
        <div class="row">
          <a class="btn btn-primary btn-lg" href={hrefPrimario}>{ctaPrimario} <Icon name="arrow" size={18} /></a>
          {ctaSecundario && hrefSecundario && (
            <a class="btn btn-outline btn-lg" href={hrefSecundario} style="background:transparent;color:white;border-color:rgba(255,255,255,.3);">{ctaSecundario}</a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
<style>
  .cta-panel {
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, var(--brand-primary) 0%, #1E3A5F 60%, var(--brand-accent-2) 120%);
    padding: 72px 48px;
    color: white;
    position: relative;
    overflow: hidden;
  }
  .cta-panel-glow {
    position: absolute; right: -80px; top: -80px; width: 360px; height: 360px;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in srgb, var(--brand-accent) 50%, transparent) 0%, transparent 70%);
  }
  .cta-panel-ring {
    position: absolute; left: -40px; bottom: -40px; width: 220px; height: 220px;
    border-radius: 50%; border: 1px solid rgba(255,255,255,.15);
  }
  .cta-panel-inner {
    position: relative;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 32px;
  }
  @media (max-width: 720px) {
    .cta-panel { padding: 48px 28px; }
  }
</style>
