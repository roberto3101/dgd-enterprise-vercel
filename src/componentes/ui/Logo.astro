---
interface Props {
  size?: number;
  withText?: boolean;
  variant?: 'auto' | 'light' | 'dark';
}
const { size = 38, withText = true, variant = 'auto' } = Astro.props;
---
<a href="/" class="logo-wrap" aria-label="Grupo DGD · Inicio">
  <!-- Si /public/logo.png existe, se usa. Fallback: SVG inline -->
  <img src="/logo.png" alt="Grupo DGD" class="logo-img-real" style={`height:${size}px;width:auto;`} onerror="this.style.display='none';this.nextElementSibling.style.display='grid';" />
  <span class="logo-fallback" aria-hidden="true" style={`width:${size}px;height:${size}px;display:none;`}>
    <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="lg-navy" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#0E3A5F"/>
          <stop offset="1" stop-color="#072540"/>
        </linearGradient>
        <linearGradient id="lg-gold" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#E8C873"/>
          <stop offset="1" stop-color="#B78B2B"/>
        </linearGradient>
      </defs>
      <circle cx="32" cy="32" r="30" stroke="url(#lg-gold)" stroke-width="2.5" fill="url(#lg-navy)" />
      <path d="M20 44 L20 26 L32 20 L44 26 L44 44" stroke="#2E6BA5" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" />
      <path d="M32 18 L32 42" stroke="url(#lg-gold)" stroke-width="3" stroke-linecap="round" />
      <circle cx="32" cy="16" r="2.5" fill="url(#lg-gold)" />
    </svg>
  </span>
  {withText && (
    <span class="logo-text">
      <span class="logo-grupo">GRUPO</span>
      <span class="logo-dgd">DGD</span>
    </span>
  )}
</a>

<style>
  .logo-wrap {
    display: inline-flex; align-items: center; gap: 12px;
    font-weight: 700; letter-spacing: -0.01em;
    color: var(--ink-900);
    text-decoration: none;
  }
  .logo-img-real { display: block; }
  .logo-fallback { display: none; place-items: center; }
  .logo-fallback svg { width: 100%; height: 100%; display: block; }
  .logo-text { display: inline-flex; gap: 6px; align-items: baseline; font-size: 17px; }
  .logo-grupo {
    color: var(--ink-500); font-weight: 500;
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.22em; text-transform: uppercase;
  }
  .logo-dgd {
    background: linear-gradient(135deg, var(--navy-700) 0%, var(--gold-500) 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    font-weight: 800; font-size: 20px; letter-spacing: -0.01em;
  }
  :root.dark .logo-grupo { color: var(--ink-400); }
  @media (max-width: 820px) {
    .logo-text { display: none; }
  }
</style>
